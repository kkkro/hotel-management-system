@model BulkSetPriceViewModel

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Đặt giá phòng hàng loạt";
}

<div class="container-fluid py-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thành công!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold">Đặt giá phòng hàng loạt</h2>
            <p class="text-muted mb-0">Đặt giá cho nhiều phòng cùng lúc trong một khoảng thời gian.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-calendar-range me-2"></i>Bước 1: Chọn thời gian
                </div>
                <div class="card-body">
                    <form method="get" asp-action="BulkSetPrice">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Từ ngày</label>
                            <input type="date" name="tuNgay" class="form-control" value="@Model.NgayBatDau?.ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Đến ngày</label>
                            <input type="date" name="denNgay" class="form-control" value="@Model.NgayKetThuc?.ToString("yyyy-MM-dd")" />
                            <div class="form-text">Để trống nếu giá vô thời hạn</div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search me-2"></i>Tìm loại phòng chưa có giá
                        </button>
                    </form>
                </div>
            </div>

            @if (Model.LoaiPhongsChuaCoGia.Any())
            {
                <div class="card shadow-sm mb-4" id="priceFormCard" style="display: none;">
                    <div class="card-header bg-success text-white">
                        <i class="bi bi-currency-dollar me-2"></i>Bước 2: Nhập giá
                    </div>
                    <div class="card-body">
                        <form method="post" asp-action="BulkSetPrice" id="priceForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="NgayBatDau" value="@Model.NgayBatDau?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="NgayKetThuc" value="@Model.NgayKetThuc?.ToString("yyyy-MM-dd")" />

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Giá (VND/đêm)</label>
                                <div class="input-group">
                                    <input type="number" name="Gia" id="inputGia" class="form-control" placeholder="VD: 500000" min="1000" step="1000" required />
                                    <span class="input-group-text">VND</span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted">Đã chọn: <strong id="selectedCount">0</strong> loại phòng</span>
                                    <span class="badge bg-primary">Tổng: <span id="totalDisplay">0</span> VND/đêm</span>
                                </div>
                            </div>

                            <div id="selectedPhongsList" class="mb-3"></div>

                            <button type="submit" class="btn btn-success w-100" id="btnSetPrice" disabled>
                                <i class="bi bi-check-circle me-2"></i>Đặt giá cho loại phòng đã chọn
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi bi-door-closed me-2"></i>Danh sách loại phòng chưa có giá trong khoảng thời gian
                    </div>
                    <div>
                        <span class="badge bg-secondary">@Model.NgayBatDau?.ToString("dd/MM/yyyy") - @(Model.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "Vô thời hạn")</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (Model.LoaiPhongsChuaCoGia.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-3" style="width: 50px;">
                                            <input type="checkbox" class="form-check-input" id="selectAll" />
                                        </th>
                                        <th>Mã loại</th>
                                        <th>Loại phòng</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var loaiPhong in Model.LoaiPhongsChuaCoGia)
                                    {
                                        <tr>
                                            <td class="ps-3">
                                                <input type="checkbox" class="form-check-input loaiphong-checkbox" 
                                                       name="SelectedLoaiPhongIds" value="@loaiPhong.MaLoaiPhong"
                                                       data-tenloaiphong="@loaiPhong.TenLoaiPhong"
                                                       onchange="updateSelectedList()" />
                                            </td>
                                            <td>
                                                <strong>@loaiPhong.MaLoaiPhong</strong>
                                            </td>
                                            <td>
                                                <div class="fw-semibold">@loaiPhong.TenLoaiPhong</div>
                                                <small class="text-muted d-block">@loaiPhong.SoLuongPhong phòng</small>
                                            </td>
                                            <td>
                                                <span class="text-muted">Chưa có giá</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-check-circle" style="font-size: 3rem; color: #198754;"></i>
                            <p class="mt-3 mb-0">Tất cả các loại phòng đã có giá trong khoảng thời gian này!</p>
                        </div>
                    }
                </div>
            </div>

            @if (Model.LoaiPhongsChuaCoGia.Any())
            {
                <div class="mt-3 alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Hướng dẫn:</strong> Chọn các loại phòng cần đặt giá → Nhập giá → Nhấn "Đặt giá cho loại phòng đã chọn"
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var selectedLoaiPhongs = [];

            $('#selectAll').change(function () {
                var isChecked = $(this).is(':checked');
                $('.loaiphong-checkbox').prop('checked', isChecked);
                updateSelectedList();
            });

            $('.loaiphong-checkbox').change(function () {
                var allChecked = $('.loaiphong-checkbox:checked').length === $('.loaiphong-checkbox').length;
                $('#selectAll').prop('checked', allChecked);
                updateSelectedList();
            });

            $('#inputGia').on('input', function () {
                updateTotal();
            });

            function updateSelectedList() {
                selectedLoaiPhongs = [];
                var html = '<div class="list-group list-group-flush small">';

                $('.loaiphong-checkbox:checked').each(function () {
                    var maLoaiPhong = $(this).val();
                    var tenLoaiPhong = $(this).data('tenloaiphong');
                    selectedLoaiPhongs.push(maLoaiPhong);

                    html += '<div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">';
                    html += '<div><strong>' + maLoaiPhong + '</strong><br><small class="text-muted">' + tenLoaiPhong + '</small></div>';
                    html += '<input type="hidden" name="SelectedLoaiPhongIds" value="' + maLoaiPhong + '" />';
                    html += '</div>';
                });

                html += '</div>';
                $('#selectedPhongsList').html(html);

                var count = selectedLoaiPhongs.length;
                $('#selectedCount').text(count);
                $('#btnSetPrice').prop('disabled', count === 0);

                if (count > 0) {
                    $('#priceFormCard').show();
                }

                updateTotal();
            }

            function updateTotal() {
                var gia = parseInt($('#inputGia').val()) || 0;
                var count = selectedLoaiPhongs.length;
                var total = gia * count;
                $('#totalDisplay').text(total.toLocaleString('vi-VN'));
            }

            updateSelectedList();
        });
    </script>
}