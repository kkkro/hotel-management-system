@model IEnumerable<WebKhachSan.Models.GiaPhong>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Quản lý Giá Phòng";
}

<div class="container-fluid py-4">
    <!-- Alert thông báo -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thành công!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold">Giá Phòng</h2>
            <p class="text-muted">Quản lý bảng giá cho các loại phòng khách sạn</p>
            @if (!string.IsNullOrEmpty(ViewBag.TenLoaiPhong))
            {
                <p class="text-info small">Loại phòng: <strong>@ViewBag.TenLoaiPhong</strong></p>
            }
        </div>
        <a asp-action="Create" asp-route-maLoaiPhong="@ViewBag.MaLoaiPhong" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle"></i> Thêm giá mới
        </a>
    </div>

    <!-- Bảng danh sách -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 fw-bold text-uppercase text-muted small">Mã Giá</th>
                        <th class="fw-bold text-uppercase text-muted small">Loại Phòng</th>
                        <th class="text-end fw-bold text-uppercase text-muted small">Giá (VND)</th>
                        <th class="fw-bold text-uppercase text-muted small">Ngày Bắt Đầu</th>
                        <th class="fw-bold text-uppercase text-muted small">Ngày Kết Thúc</th>
                        <th class="text-center fw-bold text-uppercase text-muted small">Trạng Thái</th>
                        <th class="text-center fw-bold text-uppercase text-muted small">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count() > 0)
                    {
                        @foreach (var item in Model)
                        {
                            var isActive = item.NgayBatDau <= DateTime.Now && 
                                          (item.NgayKetThuc == null || item.NgayKetThuc >= DateTime.Now);
                            var statusClass = isActive ? "bg-success" : "bg-danger";
                            var statusText = isActive ? "Đang áp dụng" : "Hết hạn";
                            
                            <tr>
                                <td class="ps-4 fw-semibold text-primary">@item.MaGia</td>
                                <td class="fw-semibold">@item.MaLoaiPhongNavigation?.TenLoaiPhong</td>
                                <td class="text-end fw-bold">@item.Gia?.ToString("N0")</td>
                                <td>@item.NgayBatDau?.ToString("dd/MM/yyyy")</td>
                                <td>@(item.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "(Không giới hạn)")</td>
                                <td class="text-center">
                                    <span class="badge @statusClass">@statusText</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.MaGia" class="btn btn-outline-warning" title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaGia" class="btn btn-outline-danger" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                <p class="mt-3">Chưa có giá phòng nào</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
