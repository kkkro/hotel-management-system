@model WebKhachSan.Models.GiaPhong

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Thêm giá phòng";
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="LoaiPhong" asp-action="Index">Loại phòng</a></li>
            <li class="breadcrumb-item"><a asp-controller="GiaPhong" asp-action="Index" asp-route-maLoaiPhong="@ViewBag.MaLoaiPhong">Giá phòng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Thêm mới</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-1 fw-bold">Thêm Giá Phòng</h2>
            <p class="text-muted">Thêm bảng giá mới cho loại phòng</p>
        </div>
    </div>

    <!-- Form -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Mã Giá -->
                        <div class="mb-3">
                            <label asp-for="MaGia" class="form-label fw-semibold">Mã Giá <span class="text-danger">*</span></label>
                            @{
                                var maGiaClass = ViewData.ModelState.IsValid ? "form-control" : ViewBag.MaGiaError != null ? "form-control is-invalid" : "form-control";
                            }
                            <input asp-for="MaGia" class="@maGiaClass" placeholder="VD: G001" required>
                            <span asp-validation-for="MaGia" class="text-danger small"></span>
                            @if (ViewBag.MaGiaError != null)
                            {
                                <small class="text-danger d-block mt-1">@ViewBag.MaGiaError</small>
                            }
                        </div>

                        <!-- Loại Phòng -->
                        <div class="mb-3">
                            <label asp-for="MaLoaiPhong" class="form-label fw-semibold">Loại Phòng <span class="text-danger">*</span></label>
                            @{
                                var maloaiPhongClass = ViewData.ModelState.IsValid ? "form-select" : ViewBag.MaLoaiPhongError != null ? "form-select is-invalid" : "form-select";
                            }
                            <select asp-for="MaLoaiPhong" class="@maloaiPhongClass" required>
                                <option value="">-- Chọn loại phòng --</option>
                                @foreach (var loaiPhong in ViewBag.LoaiPhongs)
                                {
                                    var isSelected = loaiPhong.MaLoaiPhong == Model?.MaLoaiPhong || loaiPhong.MaLoaiPhong == ViewBag.MaLoaiPhong;
                                    <option value="@loaiPhong.MaLoaiPhong" selected="@isSelected">
                                        @loaiPhong.TenLoaiPhong
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="MaLoaiPhong" class="text-danger small"></span>
                            @if (ViewBag.MaLoaiPhongError != null)
                            {
                                <small class="text-danger d-block mt-1">@ViewBag.MaLoaiPhongError</small>
                            }
                        </div>

                        <!-- Giá -->
                        <div class="mb-3">
                            <label asp-for="Gia" class="form-label fw-semibold">Giá (VND) <span class="text-danger">*</span></label>
                            @{
                                var giaClass = ViewData.ModelState.IsValid ? "form-control" : ViewBag.GiaError != null ? "form-control is-invalid" : "form-control";
                            }
                            <div class="input-group">
                                <span class="input-group-text">₫</span>
                                <input asp-for="Gia" type="number" step="1000" class="@giaClass" placeholder="VD: 500000" required>
                            </div>
                            <span asp-validation-for="Gia" class="text-danger small"></span>
                            @if (ViewBag.GiaError != null)
                            {
                                <small class="text-danger d-block mt-1">@ViewBag.GiaError</small>
                            }
                        </div>

                        <!-- Ngày Bắt Đầu -->
                        <div class="mb-3">
                            <label asp-for="NgayBatDau" class="form-label fw-semibold">Ngày Bắt Đầu <span class="text-danger">*</span></label>
                            @{
                                var ngayBatDauClass = ViewData.ModelState.IsValid ? "form-control" : ViewBag.NgayBatDauError != null ? "form-control is-invalid" : "form-control";
                            }
                            <input asp-for="NgayBatDau" type="date" class="@ngayBatDauClass" required>
                            <span asp-validation-for="NgayBatDau" class="text-danger small"></span>
                            @if (ViewBag.NgayBatDauError != null)
                            {
                                <small class="text-danger d-block mt-1">@ViewBag.NgayBatDauError</small>
                            }
                            <small class="text-muted d-block mt-1">Bảng giá sẽ bắt đầu có hiệu lực từ ngày này</small>
                        </div>

                        <!-- Ngày Kết Thúc -->
                        <div class="mb-3">
                            <label asp-for="NgayKetThuc" class="form-label fw-semibold">Ngày Kết Thúc <span class="text-muted">(Tùy chọn)</span></label>
                            @{
                                var ngayKetThucClass = ViewData.ModelState.IsValid ? "form-control" : ViewBag.NgayKetThucError != null ? "form-control is-invalid" : "form-control";
                            }
                            <input asp-for="NgayKetThuc" type="date" class="@ngayKetThucClass">
                            <span asp-validation-for="NgayKetThuc" class="text-danger small"></span>
                            @if (ViewBag.NgayKetThucError != null)
                            {
                                <small class="text-danger d-block mt-1">@ViewBag.NgayKetThucError</small>
                            }
                            <small class="text-muted d-block mt-1">Để trống nếu muốn bảng giá áp dụng vĩnh viễn, hoặc nhập ngày kết thúc</small>
                        </div>

                        <!-- Button -->
                        <div class="d-grid gap-2 d-sm-flex">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle"></i> Thêm Giá Phòng
                            </button>
                            <a asp-action="Index" asp-route-maLoaiPhong="@ViewBag.MaLoaiPhong" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-left"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Hướng dẫn -->
        <div class="col-lg-4">
            <div class="card bg-light border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-title fw-bold mb-3">
                        <i class="bi bi-info-circle text-info"></i> Hướng dẫn
                    </h6>
                    <ul class="small list-unstyled">
                        <li class="mb-2">
                            <strong>Mã Giá:</strong> Định danh duy nhất cho bảng giá, VD: G001, G002...
                        </li>
                        <li class="mb-2">
                            <strong>Loại Phòng:</strong> Chọn loại phòng mà bảng giá này áp dụng
                        </li>
                        <li class="mb-2">
                            <strong>Giá:</strong> Nhập giá tiền theo đơn vị VND
                        </li>
                        <li class="mb-2">
                            <strong>Ngày Bắt Đầu:</strong> Ngày bắt đầu áp dụng bảng giá này
                        </li>
                        <li class="mb-2">
                            <strong>Ngày Kết Thúc:</strong> Nếu để trống, bảng giá sẽ áp dụng lâu dài
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
