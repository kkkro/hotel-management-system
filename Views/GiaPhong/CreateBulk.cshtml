@model GiaPhongBulkCreateViewModel

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Gan gia hang loat";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chu</a></li>
            <li class="breadcrumb-item"><a asp-controller="LoaiPhong" asp-action="Index">Loai phong</a></li>
            <li class="breadcrumb-item"><a asp-controller="GiaPhong" asp-action="Index">Gia phong</a></li>
            <li class="breadcrumb-item active" aria-current="page">Gan gia hang loat</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h2 class="fw-bold mb-1">Gan gia cho nhieu loai phong</h2>
                    <p class="text-muted mb-4">Moi loai phong duoc chon se nhan mot bang gia moi voi cung muc gia va thoi gian ap dung.</p>

                    <form method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        @foreach (var selectedId in Model.SelectedLoaiPhongIds)
                        {
                            <input type="hidden" name="SelectedLoaiPhongIds" value="@selectedId" />
                        }

                        <div class="mb-3">
                            <label asp-for="Gia" class="form-label fw-semibold">Gia phong (VND)</label>
                            <div class="input-group">
                                <span class="input-group-text">?</span>
                                <input asp-for="Gia" type="number" step="1000" class="form-control" />
                            </div>
                            <span asp-validation-for="Gia" class="text-danger small"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="NgayBatDau" class="form-label fw-semibold">Ngay bat dau</label>
                                <input asp-for="NgayBatDau" type="date" class="form-control" />
                                <span asp-validation-for="NgayBatDau" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NgayKetThuc" class="form-label fw-semibold">Ngay ket thuc</label>
                                <input asp-for="NgayKetThuc" type="date" class="form-control" />
                                <span asp-validation-for="NgayKetThuc" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Tao bang gia
                            </button>
                            <a asp-controller="LoaiPhong" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lai loai phong
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0">Loai phong da chon</h5>
                        <span class="badge bg-primary">@Model.LoaiPhongApDung.Count loai</span>
                    </div>

                    @if (Model.LoaiPhongApDung.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Loai phong</th>
                                        <th class="text-center">So phong</th>
                                        <th class="text-end">Gia hien tai</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var loaiPhong in Model.LoaiPhongApDung)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@loaiPhong.TenLoaiPhong</div>
                                                <small class="text-muted">@loaiPhong.MaLoaiPhong</small>
                                            </td>
                                            <td class="text-center">@loaiPhong.SoLuongPhong</td>
                                            <td class="text-end">@(loaiPhong.GiaHienTai?.ToString("N0") ?? "Chua co")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">Khong co loai phong hop le.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
