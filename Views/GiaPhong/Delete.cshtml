@model WebKhachSan.Models.GiaPhong

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Xóa giá phòng";
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="LoaiPhong" asp-action="Index">Loại phòng</a></li>
            <li class="breadcrumb-item"><a asp-controller="GiaPhong" asp-action="Index" asp-route-maLoaiPhong="@Model.MaLoaiPhong">Giá phòng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Xóa</li>
        </ol>
    </nav>

    <!-- Alert Warning -->
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i>
        <strong>Cảnh báo!</strong> Bạn sắp xóa bảng giá này. Hành động này không thể hoàn tác.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

    <!-- Xác nhận xóa -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-danger border-3">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-trash"></i> Xác Nhận Xóa Bảng Giá</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <p class="text-muted mb-3">Bạn có chắc chắn muốn xóa bảng giá sau? Thao tác này không thể hoàn tác.</p>
                        
                        <!-- Thông tin chi tiết -->
                        <div class="list-group">
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">Mã Giá</h6>
                                    <strong class="text-primary">@Model.MaGia</strong>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">Loại Phòng</h6>
                                    <strong>@Model.MaLoaiPhongNavigation?.TenLoaiPhong</strong>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">Giá (VND)</h6>
                                    <strong>@Model.Gia?.ToString("N0")</strong>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">Ngày Bắt Đầu</h6>
                                    <strong>@Model.NgayBatDau?.ToString("dd/MM/yyyy")</strong>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">Ngày Kết Thúc</h6>
                                    <strong>@(Model.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "Không giới hạn")</strong>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">Trạng Thái</h6>
                                    @{
                                        var isActive = Model.NgayBatDau <= DateTime.Now && 
                                                      (Model.NgayKetThuc == null || Model.NgayKetThuc >= DateTime.Now);
                                        var statusClass = isActive ? "bg-success" : "bg-danger";
                                        var statusText = isActive ? "Đang áp dụng" : "Hết hạn";
                                    }
                                    <span class="badge @statusClass">@statusText</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <form method="post">
                        <div class="d-grid gap-2 d-sm-flex">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash"></i> Xóa Vĩnh Viễn
                            </button>
                            <a asp-action="Index" asp-route-maLoaiPhong="@Model.MaLoaiPhong" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-left"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- INFO -->
        <div class="col-lg-4">
            <div class="card bg-warning bg-opacity-10 border-warning shadow-sm">
                <div class="card-body">
                    <h6 class="card-title fw-bold mb-3">
                        <i class="bi bi-info-circle text-warning"></i> Lưu ý
                    </h6>
                    <ul class="small list-unstyled">
                        <li class="mb-2">
                            ⚠️ Xóa bảng giá sẽ làm mất dữ liệu giá lịch sử
                        </li>
                        <li class="mb-2">
                            ✓ Bạn có thể tạo lại bảng giá này sau nếu cần
                        </li>
                        <li class="mb-2">
                            ℹ️ Điều này chỉ ảnh hưởng đến bảng giá, không ảnh hưởng đến các đặt phòng hiện tại
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
