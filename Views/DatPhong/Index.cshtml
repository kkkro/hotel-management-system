@model IEnumerable<DatPhong>

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Quan Ly Dat Phong";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0" style="color: var(--primary); font-weight: 800; font-family: 'Manrope';">
                Danh Sach Dat Phong
            </h1>
            <p class="text-muted small mt-2">Quan ly tat ca cac don dat phong</p>
        </div>
        <a asp-action="CreateModern" class="btn btn-primary" style="background: linear-gradient(135deg, #00236f, #1e3a8a);">
            <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem; font-size: 1.25rem;">add_circle</span>
            Tao Don Moi
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover" style="background: white; border-radius: 1rem; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                <thead style="background: #f8f9ff; border-bottom: 2px solid #e6eeff;">
                    <tr>
                        <th style="color: #00236f; font-weight: 700;">Ma DP</th>
                        <th style="color: #00236f; font-weight: 700;">Khach Hang</th>
                        <th style="color: #00236f; font-weight: 700;">Ngay Dat</th>
                        <th style="color: #00236f; font-weight: 700;">Nhan / Tra</th>
                        <th style="color: #00236f; font-weight: 700;">Trang Thai</th>
                        <th style="color: #00236f; font-weight: 700;" class="text-center">Hanh Dong</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var statusColor = item.TrangThai switch
                        {
                            "Chưa nhận phòng" => "#ffb95f",
                            "Chờ xác nhận" => "#ffb95f",
                            "Đã xác nhận" => "#ffb95f",
                            "Đã nhận phòng" => "#0d6efd",
                            "Đã checkin" => "#0d6efd",
                            "Đã hủy" => "#b3261e",
                            _ => "#757682"
                        };
                        var canCheckIn = item.TrangThai == "Chưa nhận phòng" || item.TrangThai == "Đã xác nhận";

                        <tr style="border-bottom: 1px solid #eff4ff;">
                            <td style="font-weight: 600; color: #00236f;">@item.MaDatPhong</td>
                            <td>
                                @(item.MaKhachHangNavigation?.TenKhachHang ?? "N/A")<br />
                                <small style="color: #757682;">@item.MaKhachHangNavigation?.DienThoai</small>
                            </td>
                            <td>@item.NgayDat:dd/MM/yyyy</td>
                            <td>
                                <small>@item.NgayNhanDuKien:dd/MM/yyyy</small><br />
                                <small style="color: #757682;">-> @item.NgayTraDuKien:dd/MM/yyyy</small>
                            </td>
                            <td>
                                <span class="badge" style="background-color: @statusColor; color: white; padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-weight: 600;">
                                    @item.TrangThai
                                </span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.MaDatPhong" class="btn btn-sm" style="background: #e6eeff; color: #00236f; padding: 0.5rem 0.75rem; border-radius: 0.375rem; text-decoration: none; margin: 0 0.25rem;">
                                    <span class="material-icons" style="font-size: 1rem;">info</span>
                                </a>
                                @if (item.TrangThai == "Chờ xác nhận")
                                {
                                    <form asp-action="Confirm" asp-route-id="@item.MaDatPhong" method="post" style="display: inline-block; margin: 0 0.25rem;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm" style="background: #006c49; color: white; padding: 0.5rem 0.75rem; border-radius: 0.375rem; border: none;" title="Xac nhan don">
                                            <span class="material-icons" style="font-size: 1rem;">task_alt</span>
                                        </button>
                                    </form>
                                }
                                @if (canCheckIn)
                                {
                                    <button type="button" class="btn btn-sm js-checkin-datphong" data-id="@item.MaDatPhong" style="background: #0d6efd; color: white; padding: 0.5rem 0.75rem; border-radius: 0.375rem; border: none; margin: 0 0.25rem;" title="Checkin">
                                        <span class="material-icons" style="font-size: 1rem;">login</span>
                                    </button>
                                }
                                <a asp-action="Delete" asp-route-id="@item.MaDatPhong" class="btn btn-sm" style="background: #ffb95f33; color: #ffb95f; padding: 0.5rem 0.75rem; border-radius: 0.375rem; text-decoration: none;">
                                    <span class="material-icons" style="font-size: 1rem;">delete</span>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 3rem; background: #f8f9ff; border-radius: 1rem;">
            <span class="material-icons" style="font-size: 4rem; color: #c5c5d3; margin-bottom: 1rem;">folder_open</span>
            <p style="color: #757682; font-size: 1.125rem;">Chua co don dat phong nao. <a asp-action="CreateModern" style="color: #00236f; font-weight: 600;">Tao don moi</a></p>
        </div>
    }
</div>

<div class="modal fade" id="checkInDatPhongModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Checkin Don Dat Phong</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="checkInDatPhongModalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huy</button>
                <button type="button" class="btn btn-primary" id="btnConfirmCheckInDatPhong">
                    <i class="bi bi-check-circle"></i> Xac nhan checkin
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary: #00236f;
        --surface: #f8f9ff;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            let checkInModal;

            $(document).on('click', '.js-checkin-datphong', function () {
                const id = $(this).data('id');
                $.get('/DatPhong/CheckIn', { id: id }, function (html) {
                    $('#checkInDatPhongModalBody').html(html);
                    checkInModal = new bootstrap.Modal($('#checkInDatPhongModal'));
                    checkInModal.show();
                }).fail(function () {
                    toastr.error('Khong the tai form checkin.');
                });
            });

            $(document).on('click', '#btnConfirmCheckInDatPhong', function () {
                const form = $('#checkInForm');
                if (!form.length) {
                    return;
                }

                $.ajax({
                    url: '/DatPhong/CheckIn',
                    type: 'POST',
                    data: form.serialize(),
                    success: function (response) {
                        if (response.success) {
                            checkInModal.hide();
                            toastr.success(response.message);
                            setTimeout(function () {
                                location.reload();
                            }, 1200);
                        } else {
                            toastr.error(response.message || 'Khong the checkin don dat phong.');
                        }
                    },
                    error: function (xhr) {
                        const contentType = xhr.getResponseHeader('content-type') || '';
                        if (contentType.indexOf('text/html') >= 0) {
                            $('#checkInDatPhongModalBody').html(xhr.responseText);
                        } else {
                            toastr.error('Khong the checkin don dat phong.');
                        }
                    }
                });
            });
        });
    </script>
}
