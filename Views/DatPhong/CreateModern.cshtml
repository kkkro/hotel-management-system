@{
    Layout = "_DashboardLayout";
}

@{
    IEnumerable<SelectListItem> loaiPhongList;
    if (ViewBag.LoaiPhong != null)
    {
        loaiPhongList = (IEnumerable<SelectListItem>)ViewBag.LoaiPhong;
    }
    else
    {
        loaiPhongList = new List<SelectListItem>();
    }
}

<style>
    :root {
        --primary: #00236f;
        --primary-container: #1e3a8a;
        --secondary: #006c49;
        --secondary-fixed: #6ffbbe;
        --surface: #f8f9ff;
        --surface-container-low: #eff4ff;
        --surface-container: #e6eeff;
        --surface-container-highest: #d5e3fc;
        --surface-container-lowest: #ffffff;
        --on-surface: #0d1c2e;
        --on-surface-variant: #444651;
        --outline: #757682;
        --outline-variant: #c5c5d3;
        --error: #b3261e;
        --success: #186638;
    }

    .page-header {
        margin-bottom: 2.5rem;
    }

    .page-title {
        font-family: 'Manrope', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        color: var(--primary);
        margin-bottom: 0.5rem;
    }

    .page-subtitle {
        color: var(--on-surface-variant);
        font-size: 0.95rem;
    }

    .booking-container {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 1024px) {
        .booking-container {
            grid-template-columns: 1fr;
        }
    }

    .booking-form {
        background: var(--surface-container-lowest);
        border-radius: 1.25rem;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .form-section {
        margin-bottom: 2.5rem;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid var(--outline-variant);
    }

    .form-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .section-title {
        font-family: 'Manrope', sans-serif;
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--on-surface);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .section-icon {
        width: 2rem;
        height: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--primary), var(--primary-container));
        color: white;
        border-radius: 0.5rem;
        font-size: 1.25rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-weight: 600;
        color: var(--on-surface);
        font-size: 0.875rem;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .form-control, .form-select {
        background: var(--surface-container-highest);
        border: 1px solid var(--outline-variant);
        border-radius: 0.5rem;
        padding: 0.75rem 1rem;
        color: var(--on-surface);
        font-family: 'Inter', sans-serif;
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(0, 35, 111, 0.1);
        background: var(--surface-container-lowest);
    }

    .input-group-text {
        background: var(--surface-container-highest);
        border: 1px solid var(--outline-variant);
        color: var(--on-surface-variant);
    }

    .search-results {
        background: var(--surface-container-low);
        border-radius: 1.25rem;
        padding: 2rem;
        display: none;
        max-height: 600px;
        overflow-y: auto;
    }

    .search-results.show {
        display: block;
    }

    .room-item {
        background: var(--surface-container-lowest);
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 1rem;
        border: 2px solid transparent;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .room-item:hover {
        border-color: var(--primary);
        box-shadow: 0 4px 12px rgba(0, 35, 111, 0.1);
    }

    .room-item.selected {
        background: linear-gradient(135deg, rgba(0, 35, 111, 0.05), rgba(30, 58, 138, 0.05));
        border-color: var(--primary);
    }

    .room-name {
        font-weight: 700;
        color: var(--on-surface);
        margin-bottom: 0.5rem;
    }

    .room-info {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        font-size: 0.875rem;
        color: var(--on-surface-variant);
    }

    .room-price {
        font-weight: 700;
        color: var(--primary);
    }

    .sidebar {
        position: sticky;
        top: 2rem;
    }

    .info-card {
        background: linear-gradient(135deg, var(--primary), var(--primary-container));
        color: white;
        border-radius: 1.25rem;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 8px 24px rgba(0, 35, 111, 0.15);
    }

    .info-card h3 {
        font-family: 'Manrope', sans-serif;
        font-size: 1.125rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .price-summary {
        display: grid;
        gap: 1rem;
    }

    .price-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.875rem;
    }

    .price-row.total {
        padding-top: 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.2);
        font-weight: 700;
        font-size: 1.125rem;
    }

    .alert-custom {
        background: var(--surface-container);
        border-left: 4px solid var(--primary);
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 1.5rem;
    }

    .modal-header {
        background: linear-gradient(135deg, var(--primary), var(--primary-container));
        color: white;
        border: none;
    }

    .modal-body {
        background: var(--surface);
    }

    .btn-primary-custom {
        background: linear-gradient(135deg, var(--primary), var(--primary-container));
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-primary-custom:hover {
        opacity: 0.9;
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0, 35, 111, 0.2);
    }

    .btn-primary-custom:active {
        transform: translateY(0);
    }

    .btn-secondary-custom {
        background: var(--surface-container);
        color: var(--primary);
        border: 2px solid var(--primary);
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-secondary-custom:hover {
        background: var(--primary);
        color: white;
    }

    .material-icons {
        font-size: 1.25rem !important;
    }

    .badge-status {
        display: inline-block;
        padding: 0.5rem 0.75rem;
        border-radius: 0.375rem;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .badge-available {
        background: rgba(24, 102, 56, 0.15);
        color: #186638;
    }

    .badge-booked {
        background: rgba(179, 38, 30, 0.15);
        color: #b3261e;
    }

    .step-indicator {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: var(--surface-container);
        border-radius: 0.75rem;
    }

    .step {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex: 1;
        padding: 0.75rem;
        border-radius: 0.5rem;
        background: var(--surface-container-lowest);
        position: relative;
    }

    .step.active {
        background: linear-gradient(135deg, rgba(0, 35, 111, 0.1), rgba(30, 58, 138, 0.1));
        border-left: 4px solid var(--primary);
    }

    .step-number {
        width: 2rem;
        height: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--surface-container-high);
        border-radius: 0.5rem;
        font-weight: 700;
        color: var(--on-surface);
        flex-shrink: 0;
    }

    .step.active .step-number {
        background: linear-gradient(135deg, var(--primary), var(--primary-container));
        color: white;
    }

    .row-two-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    @@media (max-width: 768px) {
        .row-two-cols {
            grid-template-columns: 1fr;
        }

        .booking-container {
            grid-template-columns: 1fr;
        }

        .sidebar {
            position: static;
        }

        .page-title {
            font-size: 1.5rem;
        }
    }
</style>

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="page-header">
        <h1 class="page-title">
            <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem;">event_available</span>
            Quản Lý Đặt Phòng
        </h1>
        <p class="page-subtitle">Tìm phòng trống và tạo đơn đặt phòng mới cho khách hàng</p>
    </div>

    <!-- Step Indicator -->
    <div class="step-indicator">
        <div class="step active" id="step1">
            <div class="step-number">1</div>
            <div>
                <strong style="display: block; font-size: 0.875rem; color: var(--on-surface);">Bước 1</strong>
                <span style="font-size: 0.75rem; color: var(--on-surface-variant);">Tìm Phòng Trống</span>
            </div>
        </div>
        <div class="step" id="step2">
            <div class="step-number">2</div>
            <div>
                <strong style="display: block; font-size: 0.875rem; color: var(--on-surface);">Bước 2</strong>
                <span style="font-size: 0.75rem; color: var(--on-surface-variant);">Chọn Khách Hàng</span>
            </div>
        </div>
        <div class="step" id="step3">
            <div class="step-number">3</div>
            <div>
                <strong style="display: block; font-size: 0.875rem; color: var(--on-surface);">Bước 3</strong>
                <span style="font-size: 0.75rem; color: var(--on-surface-variant);">Xác Nhận Đặt Phòng</span>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
    {
        <div class="alert alert-danger alert-custom" role="alert">
            <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem;">error</span>
            @ViewBag.ErrorMessage
        </div>
    }

    <!-- Main Booking Container -->
    <div class="booking-container">
        <!-- Left: Booking Form -->
        <form asp-action="Create" method="post" id="bookingForm" class="booking-form">
            <!-- Step 1: Search Section -->
            <div class="form-section" id="searchSection">
                <div class="section-title">
                    <div class="section-icon">
                        <span class="material-icons">search</span>
                    </div>
                    Tìm Phòng Trống
                </div>

                <div class="row-two-cols">
                    <div class="form-group">
                        <label class="form-label">Ngày Nhận Phòng</label>
                        <input type="date" id="ngayNhan" class="form-control" required/>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Ngày Trả Phòng</label>
                        <input type="date" id="ngayTra" class="form-control" required/>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Loại Phòng</label>
                    <select id="loaiPhong" class="form-select" required>
                        <option value="">-- Chọn loại phòng --</option>
                        @foreach (var item in loaiPhongList)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Số Lượng Phòng</label>
                    <input type="number" id="soLuong" class="form-control" value="1" min="1" required/>
                </div>

                <button type="button" class="btn-primary-custom w-100" id="btnTim">
                    <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem;">search</span>
                    Tìm Phòng Ngay
                </button>
            </div>

            <!-- Search Results -->
            <div class="search-results" id="searchResults">
                <h6 style="font-weight: 700; margin-bottom: 1rem;">Phòng Trống Có Sẵn:</h6>
                <div id="roomList"></div>
            </div>

            <!-- Step 2: Customer Selection -->
            <div class="form-section" id="customerSection" style="display: none;">
                <div class="section-title">
                    <div class="section-icon">
                        <span class="material-icons">person</span>
                    </div>
                    Thông Tin Khách Hàng
                </div>

                <div class="form-group">
                    <label class="form-label">Chọn Khách Hàng Có Sẵn</label>
                    <div style="display: flex; gap: 0.5rem;">
                        <select id="maKhachHang" class="form-select" style="flex: 1;">
                            <option value="">-- Chọn khách hàng --</option>
                        </select>
                        <button type="button" class="btn-secondary-custom" data-bs-toggle="modal" data-bs-target="#addCustomerModal">
                            <span class="material-icons">add_circle</span>
                        </button>
                    </div>
                </div>

                <div id="customerInfo" style="padding: 1rem; background: var(--surface-container); border-radius: 0.75rem; display: none;">
                    <div style="font-size: 0.875rem; margin-bottom: 0.5rem;">
                        <strong>Tên Khách:</strong> <span id="customerName">--</span>
                    </div>
                    <div style="font-size: 0.875rem; margin-bottom: 0.5rem;">
                        <strong>Điện Thoại:</strong> <span id="customerPhone">--</span>
                    </div>
                    <div style="font-size: 0.875rem;">
                        <strong>Địa Chỉ:</strong> <span id="customerAddress">--</span>
                    </div>
                </div>
            </div>

            <!-- Step 3: Booking Confirmation -->
            <div class="form-section" id="confirmSection" style="display: none;">
                <div class="section-title">
                    <div class="section-icon">
                        <span class="material-icons">check_circle</span>
                    </div>
                    Xác Nhận Đặt Phòng
                </div>

                <div style="padding: 1rem; background: var(--surface-container-low); border-radius: 0.75rem; margin-bottom: 1rem;">
                    <div style="font-size: 0.875rem; margin-bottom: 0.75rem;">
                        <strong>Loại Phòng:</strong> <span id="summaryRoomType">--</span>
                    </div>
                    <div style="font-size: 0.875rem; margin-bottom: 0.75rem;">
                        <strong>Ngày Nhận:</strong> <span id="summaryNgayNhan">--</span> → <strong>Ngày Trả:</strong> <span id="summaryNgayTra">--</span>
                    </div>
                    <div style="font-size: 0.875rem; margin-bottom: 0.75rem;">
                        <strong>Số Lượng Phòng:</strong> <span id="summarySoLuong">--</span>
                    </div>
                    <div style="font-size: 0.875rem;">
                        <strong>Tổng Giá:</strong> <span id="summaryTotal" style="font-weight: 700; color: var(--primary); font-size: 1.125rem;">--</span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Ghi Chú Thêm</label>
                    <textarea class="form-control" name="GhiChu" rows="3" placeholder="Nhập ghi chú..."></textarea>
                </div>

                <button type="submit" class="btn-primary-custom w-100">
                    <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem;">done_all</span>
                    Tạo Đơn Đặt Phòng
                </button>
            </div>

            <!-- Hidden Inputs -->
            <input type="hidden" id="hfMaLoaiPhong" name="MaLoaiPhong" value=""/>
            <input type="hidden" id="hfNgayDat" name="NgayDat" value=""/>
            <input type="hidden" id="hfNgayNhanDuKien" name="NgayNhanDuKien" value=""/>
            <input type="hidden" id="hfNgayTraDuKien" name="NgayTraDuKien" value=""/>
            <input type="hidden" id="hfMaKhachHang" name="MaKhachHang" value=""/>
        </form>

        <!-- Right: Price Summary Sidebar -->
        <div class="sidebar">
            <div class="info-card">
                <h3>📊 Tóm Tắt Đơn</h3>
                <div class="price-summary">
                    <div class="price-row">
                        <span>Loại phòng:</span>
                        <strong id="sidebarType">Chưa chọn</strong>
                    </div>
                    <div class="price-row">
                        <span>Số đêm:</span>
                        <strong id="sidebarNights">--</strong>
                    </div>
                    <div class="price-row">
                        <span>Giá/đêm:</span>
                        <strong id="sidebarPrice">--</strong>
                    </div>
                    <div class="price-row">
                        <span>Số phòng:</span>
                        <strong id="sidebarQty">1</strong>
                    </div>
                    <div class="price-row total">
                        <span>TỔNG CỘNG:</span>
                        <strong id="sidebarTotal">0 ₫</strong>
                    </div>
                </div>
            </div>

            <div style="background: var(--surface-container-low); border-radius: 1.25rem; padding: 2rem; border-left: 4px solid var(--primary);">
                <h5 style="font-weight: 700; margin-bottom: 1rem; color: var(--on-surface);">💡 Hướng Dẫn</h5>
                <ol style="font-size: 0.875rem; color: var(--on-surface-variant); line-height: 1.6; margin-bottom: 0;">
                    <li>Chọn ngày nhận/trả phòng</li>
                    <li>Tìm kiếm phòng trống</li>
                    <li>Chọn khách hàng</li>
                    <li>Xác nhận và tạo đơn</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Add New Customer -->
<div class="modal fade" id="addCustomerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thêm Khách Hàng Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addCustomerForm">
                    <div class="form-group mb-3">
                        <label class="form-label">Tên Khách Hàng</label>
                        <input type="text" id="newCustomerName" class="form-control" required/>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Số Điện Thoại</label>
                        <input type="tel" id="newCustomerPhone" class="form-control" required/>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Địa Chỉ</label>
                        <input type="text" id="newCustomerAddress" class="form-control" required/>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input type="email" id="newCustomerEmail" class="form-control"/>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn-primary-custom" onclick="saveNewCustomer()">Lưu Khách Hàng</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    let selectedRoomType = null;
    let selectedRoomPrice = null;
    let selectedQty = 1;

    // Set today's date as default
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('ngayNhan').value = today;
    
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    document.getElementById('ngayTra').value = tomorrow.toISOString().split('T')[0];

    // Calculate number of days
    function calculateNights() {
        const ngayNhan = new Date(document.getElementById('ngayNhan').value);
        const ngayTra = new Date(document.getElementById('ngayTra').value);
        const nights = (ngayTra - ngayNhan) / (1000 * 60 * 60 * 24);
        return nights > 0 ? nights : 0;
    }

    // Update sidebar
    function updateSidebar() {
        const nights = calculateNights();
        document.getElementById('sidebarNights').textContent = nights > 0 ? nights : '--';
        
        if (selectedRoomPrice) {
            const total = selectedRoomPrice * nights * selectedQty;
            document.getElementById('sidebarPrice').textContent = selectedRoomPrice.toLocaleString('vi-VN') + ' ₫';
            document.getElementById('sidebarQty').textContent = selectedQty;
            document.getElementById('sidebarTotal').textContent = total.toLocaleString('vi-VN') + ' ₫';
            document.getElementById('summaryTotal').textContent = total.toLocaleString('vi-VN') + ' ₫';
        }
    }

    // Search rooms
    document.getElementById('btnTim').addEventListener('click', async function() {
        const loaiPhong = document.getElementById('loaiPhong').value;
        const ngayNhan = document.getElementById('ngayNhan').value;
        const ngayTra = document.getElementById('ngayTra').value;
        const soLuong = parseInt(document.getElementById('soLuong').value);

        if (!loaiPhong || !ngayNhan || !ngayTra) {
            alert('Vui lòng chọn đầy đủ thông tin');
            return;
        }

        selectedQty = soLuong;
        
        try {
            const response = await fetch('@Url.Action("GetAvailableRooms", "DatPhong")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    maLoaiPhong: loaiPhong,
                    ngayNhan: ngayNhan,
                    ngayTra: ngayTra
                })
            });

            const data = await response.json();
            
            if (data.success && data.phongTrongs && data.phongTrongs.length > 0) {
                // Display available rooms
                let roomHtml = '';
                data.phongTrongs.forEach(room => {
                    roomHtml += `
                        <div class="room-item" onclick="selectRoom('${room.maLoaiPhong}', '${room.tenLoaiPhong}', ${data.gia}, ${soLuong})">
                            <div class="room-name">${room.tenLoaiPhong}</div>
                            <div class="room-info">
                                <div>Mã phòng: <strong>${room.maphong}</strong></div>
                                <div class="room-price">₫ ${data.gia.toLocaleString('vi-VN')}/đêm</div>
                            </div>
                        </div>
                    `;
                });
                document.getElementById('roomList').innerHTML = roomHtml;
                document.getElementById('searchResults').classList.add('show');
                
                // Update sidebar
                document.getElementById('sidebarType').textContent = data.phongTrongs[0].tenLoaiPhong;
                selectedRoomPrice = data.gia;
                updateSidebar();
            } else {
                alert('Không có phòng trống trong giai đoạn này');
                document.getElementById('searchResults').classList.remove('show');
            }
        } catch (error) {
            console.error('Lỗi:', error);
            alert('Có lỗi xảy ra khi tìm kiếm phòng');
        }
    });

    // Select room
    function selectRoom(maLoaiPhong, tenLoaiPhong, gia, soLuong) {
        selectedRoomType = maLoaiPhong;
        selectedRoomPrice = gia;
        selectedQty = soLuong;
        
        // Update hidden fields
        document.getElementById('hfMaLoaiPhong').value = maLoaiPhong;
        document.getElementById('hfNgayNhanDuKien').value = document.getElementById('ngayNhan').value;
        document.getElementById('hfNgayTraDuKien').value = document.getElementById('ngayTra').value;
        document.getElementById('hfNgayDat').value = new Date().toISOString().split('T')[0];

        // Update summary
        document.getElementById('summaryRoomType').textContent = tenLoaiPhong;
        document.getElementById('summaryNgayNhan').textContent = document.getElementById('ngayNhan').value;
        document.getElementById('summaryNgayTra').textContent = document.getElementById('ngayTra').value;
        document.getElementById('summarySoLuong').textContent = soLuong;

        // Update sidebar and show next steps
        document.getElementById('sidebarType').textContent = tenLoaiPhong;
        updateSidebar();
        
        // Show customer section
        document.getElementById('step1').classList.remove('active');
        document.getElementById('step2').classList.add('active');
        document.getElementById('searchSection').style.display = 'none';
        document.getElementById('customerSection').style.display = 'block';
        
        // Load customers
        loadCustomers();
    }

    // Load customers
    function loadCustomers() {
        fetch('@Url.Action("GetCustomers", "KhachHang")')
            .then(r => r.json())
            .then(data => {
                let html = '<option value="">-- Chọn khách hàng --</option>';
                data.forEach(c => {
                    html += `<option value="${c.maKhachHang}" data-name="${c.tenKhachHang}" data-phone="${c.dienthoai}" data-address="${c.diachi}">${c.tenKhachHang} (${c.dienthoai})</option>`;
                });
                document.getElementById('maKhachHang').innerHTML = html;
            });
    }

    // Handle customer selection
    document.getElementById('maKhachHang').addEventListener('change', function() {
        const option = this.options[this.selectedIndex];
        if (this.value) {
            document.getElementById('customerName').textContent = option.dataset.name;
            document.getElementById('customerPhone').textContent = option.dataset.phone;
            document.getElementById('customerAddress').textContent = option.dataset.address;
            document.getElementById('customerInfo').style.display = 'block';

            document.getElementById('hfMaKhachHang').value = this.value;

            // Show confirmation section
            document.getElementById('step2').classList.remove('active');
            document.getElementById('step3').classList.add('active');
            document.getElementById('customerSection').style.display = 'none';
            document.getElementById('confirmSection').style.display = 'block';
        }
    });

    // Save new customer
    function saveNewCustomer() {
        const name = document.getElementById('newCustomerName').value;
        const phone = document.getElementById('newCustomerPhone').value;
        const address = document.getElementById('newCustomerAddress').value;
        const email = document.getElementById('newCustomerEmail').value;

        if (!name || !phone || !address) {
            alert('Vui lòng nhập đầy đủ thông tin');
            return;
        }

        fetch('@Url.Action("Create", "KhachHang")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `TenKhachHang=${encodeURIComponent(name)}&Dienthoai=${encodeURIComponent(phone)}&Diachi=${encodeURIComponent(address)}&Email=${encodeURIComponent(email)}`
        })
        .then(r => r.text())
        .then(() => {
            bootstrap.Modal.getInstance(document.getElementById('addCustomerModal')).hide();
            document.getElementById('addCustomerForm').reset();
            loadCustomers();
            alert('Khách hàng mới đã được thêm!');
        });
    }

    // Update sidebar on date change
    document.getElementById('ngayNhan').addEventListener('change', updateSidebar);
    document.getElementById('ngayTra').addEventListener('change', updateSidebar);
    document.getElementById('soLuong').addEventListener('change', function() {
        selectedQty = parseInt(this.value);
        updateSidebar();
    });

    // Initial load
    updateSidebar();
</script>
