@model DatPhong

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Chi Tiet Dat Phong";
    var soDem = Math.Max(1, ((Model.NgayTraDuKien ?? DateTime.Now) - (Model.NgayNhanDuKien ?? DateTime.Now)).Days);
    var tongTien = Model.CtdatPhongs?.Sum(ct => ct.GiaTamTinh) ?? 0;
}

<style>
    :root {
        --primary: #00236f;
        --primary-container: #1e3a8a;
        --secondary: #006c49;
        --surface: #f8f9ff;
    }

    .info-box {
        background: white;
        border-radius: 1rem;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        border-left: 4px solid var(--primary);
    }

    .info-label {
        font-size: 0.875rem;
        font-weight: 600;
        color: #757682;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .info-value {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--primary);
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0" style="color: var(--primary); font-weight: 800; font-family: 'Manrope';">
                Chi Tiet Dat Phong @Model.MaDatPhong
            </h1>
        </div>
        <div>
            <a asp-action="Index" class="btn" style="background: #e6eeff; color: var(--primary); padding: 0.75rem 1.5rem; border-radius: 0.5rem;">
                <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem;">arrow_back</span> Quay Lai
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="info-box">
                <h5 style="color: var(--primary); font-weight: 700; margin-bottom: 1.5rem; font-family: 'Manrope';">Thong Tin Dat Phong</h5>
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <div class="info-label">Ma Dat Phong</div>
                        <div class="info-value">@Model.MaDatPhong</div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="info-label">Trang Thai</div>
                        <div>
                            @{
                                string statusColor = Model.TrangThai switch
                                {
                                    "Chờ xác nhận" => "#ffb95f",
                                    "Đã xác nhận" => "#006c49",
                                    "Đã hủy" => "#b3261e",
                                    _ => "#757682"
                                };
                            }
                            <span class="badge" style="background: @statusColor; color: white; padding: 0.75rem 1rem; border-radius: 0.5rem; font-weight: 700; font-size: 0.875rem;">
                                @Model.TrangThai
                            </span>
                        </div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="info-label">Ngay Dat</div>
                        <div class="info-value">@Model.NgayDat:dd/MM/yyyy HH:mm</div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="info-label">So Dem</div>
                        <div class="info-value">@soDem đêm</div>
                    </div>
                </div>
            </div>

            <div class="info-box">
                <h5 style="color: var(--primary); font-weight: 700; margin-bottom: 1.5rem; font-family: 'Manrope';">Thong Tin Khach Hang</h5>
                @if (Model.MaKhachHangNavigation != null)
                {
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="info-label">Ten Khach Hang</div>
                            <div class="info-value">@Model.MaKhachHangNavigation.TenKhachHang</div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="info-label">Dien Thoai</div>
                            <div class="info-value">@Model.MaKhachHangNavigation.DienThoai</div>
                        </div>
                        <div class="col-12 mb-4">
                            <div class="info-label">Dia Chi</div>
                            <div class="info-value" style="font-size: 1rem;">@Model.MaKhachHangNavigation.DiaChi</div>
                        </div>
                    </div>
                }
                else
                {
                    <p style="color: #757682;">Thong tin khach hang khong kha dung</p>
                }
            </div>

            <div class="info-box">
                <h5 style="color: var(--primary); font-weight: 700; margin-bottom: 1.5rem; font-family: 'Manrope';">Chi Tiet Phong</h5>
                @if (Model.CtdatPhongs?.Count > 0)
                {
                    <div style="overflow-x: auto;">
                        <table class="table" style="margin-bottom: 0;">
                            <thead style="background: #f8f9ff;">
                                <tr>
                                    <th style="color: #00236f; font-weight: 700;">Ten Loai Phong</th>
                                    <th style="color: #00236f; font-weight: 700;">So Luong</th>
                                    <th style="color: #00236f; font-weight: 700;">Gia Tam Tinh</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ct in Model.CtdatPhongs)
                                {
                                    <tr style="border-bottom: 1px solid #eff4ff;">
                                        <td style="color: var(--primary); font-weight: 600;">@ct.MaLoaiPhongNavigation?.TenLoaiPhong</td>
                                        <td>@ct.SoLuong</td>
                                        <td style="color: var(--primary); font-weight: 700;">@ct.GiaTamTinh:N0 ₫</td>
                                    </tr>
                                }
                                <tr style="background: #f8f9ff; border-top: 2px solid #e6eeff;">
                                    <td style="font-weight: 700; color: var(--primary);">Tong Cong</td>
                                    <td></td>
                                    <td style="font-weight: 800; color: var(--primary); font-size: 1.25rem;">@tongTien.ToString("N0") ₫</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p style="color: #757682;">Chua co thong tin phong</p>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="info-box">
                <h5 style="color: var(--primary); font-weight: 700; margin-bottom: 1.5rem; font-family: 'Manrope';">Ngay O</h5>
                <div style="margin-bottom: 1rem;">
                    <div class="info-label">Ngay Nhan Phong</div>
                    <div style="font-size: 1.125rem; font-weight: 700; color: #006c49;">
                        @(Model.NgayNhanDuKien?.ToString("dd/MM/yyyy") ?? "Khong co")
                    </div>
                </div>
                <div>
                    <div class="info-label">Ngay Tra Phong</div>
                    <div style="font-size: 1.125rem; font-weight: 700; color: #b3261e;">
                        @(Model.NgayTraDuKien?.ToString("dd/MM/yyyy") ?? "Khong co")
                    </div>
                </div>
            </div>

            <div style="background: linear-gradient(135deg, var(--primary), var(--primary-container)); color: white; border-radius: 1rem; padding: 1.5rem; margin-bottom: 1.5rem; box-shadow: 0 8px 24px rgba(0, 35, 111, 0.15);">
                <h5 style="font-weight: 700; margin-bottom: 1.5rem; font-family: 'Manrope';">Tom Tat Gia</h5>
                <div style="display: grid; gap: 1rem;">
                    <div style="display: flex; justify-content: space-between; font-size: 0.875rem;">
                        <span>So dem:</span>
                        <strong>@soDem</strong>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.875rem;">
                        <span>Dong chi tiet:</span>
                        <strong>@(Model.CtdatPhongs?.Count ?? 0)</strong>
                    </div>
                    <div style="padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.2); display: flex; justify-content: space-between; font-size: 1.25rem; font-weight: 800;">
                        <span>Tong:</span>
                        <strong>@tongTien.ToString("N0") ₫</strong>
                    </div>
                </div>
            </div>

            <div style="display: grid; gap: 0.75rem;">
                <a asp-action="Delete" asp-route-id="@Model.MaDatPhong" class="btn" style="background: #ffb95f33; color: #ffb95f; padding: 0.75rem; border-radius: 0.5rem; text-decoration: none; text-align: center; font-weight: 600;">
                    <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem;">delete</span> Xoa
                </a>
            </div>
        </div>
    </div>
</div>
