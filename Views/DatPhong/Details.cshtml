@model DatPhong

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Chi Tiết Đặt Phòng";
}

<style>
    :root {
        --primary: #00236f;
        --primary-container: #1e3a8a;
        --secondary: #006c49;
        --surface: #f8f9ff;
    }

    .info-box {
        background: white;
        border-radius: 1rem;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        border-left: 4px solid var(--primary);
    }

    .info-label {
        font-size: 0.875rem;
        font-weight: 600;
        color: #757682;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .info-value {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--primary);
    }
</style>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0" style="color: var(--primary); font-weight: 800; font-family: 'Manrope';">
                📄 Chi Tiết Đặt Phòng @Model.MaDatPhong
            </h1>
        </div>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.MaDatPhong" class="btn" style="background: linear-gradient(135deg, var(--primary), var(--primary-container)); color: white; padding: 0.75rem 1.5rem; border-radius: 0.5rem; margin-right: 0.5rem;">
                <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem;">edit</span> Chỉnh Sửa
            </a>
            <a asp-action="Index" class="btn" style="background: #e6eeff; color: var(--primary); padding: 0.75rem 1.5rem; border-radius: 0.5rem;">
                <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem;">arrow_back</span> Quay Lại
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <!-- Booking Info -->
            <div class="info-box">
                <h5 style="color: var(--primary); font-weight: 700; margin-bottom: 1.5rem; font-family: 'Manrope';">📋 Thông Tin Đặt Phòng</h5>
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <div class="info-label">Mã Đặt Phòng</div>
                        <div class="info-value">@Model.MaDatPhong</div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="info-label">Trạng Thái</div>
                        <div>
                            @{
                                string statusColor = Model.TrangThai switch
                                {
                                    "Chờ xác nhận" => "#ffb95f",
                                    "Đã xác nhận" => "#006c49",
                                    "Đã hủy" => "#b3261e",
                                    _ => "#757682"
                                };
                            }
                            <span class="badge" style="background: @statusColor + "33"; color: @statusColor; padding: 0.75rem 1rem; border-radius: 0.5rem; font-weight: 700; font-size: 0.875rem;">
                                @Model.TrangThai
                            </span>
                        </div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="info-label">Ngày Đặt</div>
                        <div class="info-value">@Model.NgayDat:dd/MM/yyyy HH:mm</div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="info-label">Số Đêm</div>
                        <div class="info-value">@(((Model.NgayTraDuKien ?? DateTime.Now) - (Model.NgayNhanDuKien ?? DateTime.Now)).Days) đêm</div>
                    </div>
                </div>
            </div>

            <!-- Guest Info -->
            <div class="info-box">
                <h5 style="color: var(--primary); font-weight: 700; margin-bottom: 1.5rem; font-family: 'Manrope';">👤 Thông Tin Khách Hàng</h5>
                @if (Model.MaKhachHangNavigation != null)
                {
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="info-label">Tên Khách Hàng</div>
                            <div class="info-value">@Model.MaKhachHangNavigation.TenKhachHang</div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="info-label">Điện Thoại</div>
                            <div class="info-value">@Model.MaKhachHangNavigation.DienThoai</div>
                        </div>
                        <div class="col-12 mb-4">
                            <div class="info-label">Địa Chỉ</div>
                            <div class="info-value" style="font-size: 1rem;">@Model.MaKhachHangNavigation.DiaChi</div>
                        </div>
                    </div>
                }
                else
                {
                    <p style="color: #757682;">Thông tin khách hàng không khả dụng</p>
                }
            </div>

            <!-- Room Details -->
            <div class="info-box">
                <h5 style="color: var(--primary); font-weight: 700; margin-bottom: 1.5rem; font-family: 'Manrope';">🛏️ Chi Tiết Phòng</h5>
                @if (Model.CtdatPhongs?.Count > 0)
                {
                    <div style="overflow-x: auto;">
                        <table class="table" style="margin-bottom: 0;">
                            <thead style="background: #f8f9ff;">
                                <tr>
                                    <th style="color: #00236f; font-weight: 700;">Loại Phòng</th>
                                    <th style="color: #00236f; font-weight: 700;">Số Lượng</th>
                                    <th style="color: #00236f; font-weight: 700;">Giá Tạm Tính</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ct in Model.CtdatPhongs)
                                {
                                    <tr style="border-bottom: 1px solid #eff4ff;">
                                        <td style="color: var(--primary); font-weight: 600;">@ct.MaLoaiPhongNavigation?.TenLoaiPhong</td>
                                        <td>@ct.SoLuong</td>
                                        <td style="color: var(--primary); font-weight: 700;">@ct.GiaTamTinh:N0 ₫</td>
                                    </tr>
                                }
                                <tr style="background: #f8f9ff; border-top: 2px solid #e6eeff;">
                                    <td style="font-weight: 700; color: var(--primary);">TỔNG CỘNG</td>
                                    <td></td>
                                    <td style="font-weight: 800; color: var(--primary); font-size: 1.25rem;">@((Model.CtdatPhongs?.Sum(ct => ct.GiaTamTinh) ?? 0).ToString("N0")) ₫</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p style="color: #757682;">Chưa có thông tin phòng</p>
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Dates -->
            <div class="info-box">
                <h5 style="color: var(--primary); font-weight: 700; margin-bottom: 1.5rem; font-family: 'Manrope';">📅 Ngày Ở</h5>
                <div style="margin-bottom: 1rem;">
                    <div class="info-label">Ngày Nhận Phòng</div>
                    <div style="font-size: 1.125rem; font-weight: 700; color: #006c49;">
                        @(Model.NgayNhanDuKien?.ToString("dd/MM/yyyy") ?? "Khong co")
                    </div>
                </div>
                <div>
                    <div class="info-label">Ngay Tra Phong</div>
                    <div style="font-size: 1.125rem; font-weight: 700; color: #b3261e;">
                        @(Model.NgayTraDuKien?.ToString("dd/MM/yyyy") ?? "Khong co")
                    </div>
                </div>
            </div>

            <!-- Summary -->
            <div style="background: linear-gradient(135deg, var(--primary), var(--primary-container)); color: white; border-radius: 1rem; padding: 1.5rem; margin-bottom: 1.5rem; box-shadow: 0 8px 24px rgba(0, 35, 111, 0.15);">
                <h5 style="font-weight: 700; margin-bottom: 1.5rem; font-family: 'Manrope';">💰 Tóm Tắt Giá</h5>
                <div style="display: grid; gap: 1rem;">
                    <div style="display: flex; justify-content: space-between; font-size: 0.875rem;">
                        <span>Số đêm:</span>
                        <strong>@(((Model.NgayTraDuKien ?? DateTime.Now) - (Model.NgayNhanDuKien ?? DateTime.Now)).Days)</strong>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.875rem;">
                        <span>Số phòng:</span>
                        <strong>@(Model.CtdatPhongs?.Count ?? 0)</strong>
                    </div>
                    <div style="padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.2); display: flex; justify-content: space-between; font-size: 1.25rem; font-weight: 800;">
                        <span>Tổng:</span>
                        <strong>@((Model.CtdatPhongs?.Sum(ct => ct.GiaTamTinh) ?? 0).ToString("N0")) ₫</strong>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div style="display: grid; gap: 0.75rem;">
                <a asp-action="Edit" asp-route-id="@Model.MaDatPhong" class="btn" style="background: #e6eeff; color: var(--primary); padding: 0.75rem; border-radius: 0.5rem; text-decoration: none; text-align: center; font-weight: 600;">
                    <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem;">edit</span> Chỉnh Sửa
                </a>
                <a asp-action="Delete" asp-route-id="@Model.MaDatPhong" class="btn" style="background: #ffb95f33; color: #ffb95f; padding: 0.75rem; border-radius: 0.5rem; text-decoration: none; text-align: center; font-weight: 600;">
                    <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem;">delete</span> Xóa
                </a>
            </div>
        </div>
    </div>
</div>
