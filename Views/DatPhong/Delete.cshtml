@model DatPhong

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Xóa Đặt Phòng";
}

<style>
    :root {
        --primary: #00236f;
        --error: #b3261e;
        --surface: #f8f9ff;
    }

    .delete-container {
        background: white;
        border-radius: 1.25rem;
        padding: 2.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        max-width: 600px;
        margin: 0 auto;
        border-left: 6px solid var(--error);
    }

    .warning-icon {
        font-size: 3rem;
        margin-bottom: 1.5rem;
    }

    .delete-info {
        background: var(--surface);
        border-radius: 0.75rem;
        padding: 1rem;
        margin: 1.5rem 0;
        border-left: 4px solid var(--error);
    }

    .btn-danger {
        background: var(--error);
        color: white;
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        margin-right: 0.5rem;
    }

    .btn-cancel {
        background: #e6eeff;
        color: var(--primary);
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
    }
</style>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="mb-4">
        <h1 class="h3 mb-0" style="color: var(--error); font-weight: 800; font-family: 'Manrope';">
            ⚠️ Xác Nhận Xóa Đặt Phòng
        </h1>
        <p class="text-danger small mt-2">Hành động này không thể hoàn tác</p>
    </div>

    <div class="delete-container">
        <div class="warning-icon" style="color: var(--error);">
            <span class="material-icons" style="font-size: 3rem; vertical-align: middle;">delete_forever</span>
        </div>

        <h3 style="color: var(--primary); font-family: 'Manrope'; margin-bottom: 1rem;">Bạn có chắc chắn muốn xóa?</h3>

        <p style="color: #444651; margin-bottom: 1.5rem;">
            Bạn sắp xóa đơn đặt phòng <strong>@Model.MaDatPhong</strong>. Vui lòng xem thông tin bên dưới trước khi xác nhận.
        </p>

        <!-- Booking Details to be Deleted -->
        <div class="delete-info">
            <strong style="color: var(--error);">Thông tin sẽ bị xóa:</strong>
            <ul style="margin-top: 1rem; margin-bottom: 0;">
                <li>
                    <strong>Mã ĐP:</strong> @Model.MaDatPhong
                </li>
                <li>
                    <strong>Khách Hàng:</strong> @Model.MaKhachHangNavigation?.TenKhachHang (@Model.MaKhachHangNavigation?.DienThoai)
                </li>
                <li>
                    <strong>Ngày Đặt:</strong> @Model.NgayDat:dd/MM/yyyy HH:mm
                </li>
                <li>
                    <strong>Nhận / Trả:</strong> @Model.NgayNhanDuKien:dd/MM/yyyy → @Model.NgayTraDuKien:dd/MM/yyyy
                </li>
                <li>
                    <strong>Trạng Thái:</strong> @Model.TrangThai
                </li>
                @if (Model.CtdatPhongs?.Count > 0)
                {
                    <li>
                        <strong>Số phòng:</strong> @Model.CtdatPhongs.Count
                    </li>
                }
            </ul>
        </div>

        <div style="background: #ffb95f33; border: 1px solid #ffb95f; border-radius: 0.75rem; padding: 1rem; margin-bottom: 2rem;">
            <span class="material-icons" style="color: #ffb95f; vertical-align: middle; margin-right: 0.5rem;">info</span>
            <strong style="color: #ffb95f;">Lưu ý:</strong> Tất cả chi tiết đặt phòng sẽ bị xóa theo. Để khôi phục, bạn sẽ cần tạo đơn mới.
        </div>

        <!-- Delete Form -->
        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" name="id" value="@Model.MaDatPhong"/>

            <div style="display: flex; gap: 0.5rem;">
                <button type="submit" class="btn-danger">
                    <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem; font-size: 1.25rem;">delete</span>
                    Xác Nhận Xóa
                </button>
                <a asp-action="Details" asp-route-id="@Model.MaDatPhong" class="btn-cancel" style="display: inline-flex; align-items: center;">
                    <span class="material-icons" style="margin-right: 0.5rem; font-size: 1.25rem;">close</span>
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>
