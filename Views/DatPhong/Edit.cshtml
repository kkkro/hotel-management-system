@model DatPhong

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Chỉnh Sửa Đặt Phòng";
}

<style>
    :root {
        --primary: #00236f;
        --primary-container: #1e3a8a;
        --surface: #f8f9ff;
        --surface-container: #eff4ff;
        --on-surface: #0d1c2e;
    }

    .edit-container {
        background: white;
        border-radius: 1.25rem;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        max-width: 800px;
        margin: 0 auto;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-weight: 600;
        color: var(--on-surface);
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        border: 1px solid #c5c5d3;
        border-radius: 0.5rem;
        padding: 0.75rem 1rem;
        font-family: 'Inter', sans-serif;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(0, 35, 111, 0.1);
    }

    .btn-submit {
        background: linear-gradient(135deg, var(--primary), var(--primary-container));
        color: white;
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        margin-right: 0.5rem;
    }

    .btn-cancel {
        background: #e6eeff;
        color: var(--primary);
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
    }

    .info-box {
        background: var(--surface-container);
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 1.5rem;
        border-left: 4px solid var(--primary);
    }
</style>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="mb-4">
        <h1 class="h3 mb-0" style="color: var(--primary); font-weight: 800; font-family: 'Manrope';">
            ✏️ Chỉnh Sửa Đặt Phòng @Model.MaDatPhong
        </h1>
        <p class="text-muted small mt-2">Cập nhật thông tin đặt phòng</p>
    </div>

    <div class="edit-container">
        <!-- Original Info -->
        <div class="info-box">
            <strong style="color: var(--primary);">Thông Tin Gốc:</strong><br/>
            Mã ĐP: <strong>@Model.MaDatPhong</strong> | Khách: <strong>@Model.MaKhachHangNavigation?.TenKhachHang</strong> | Ngày đặt: <strong>@Model.NgayDat:dd/MM/yyyy</strong>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" name="MaDatPhong" value="@Model.MaDatPhong"/>

            <div class="form-group">
                <label class="form-label">Trạng Thái Đặt Phòng</label>
                <select class="form-select" name="TrangThai" required>
                    <option value="Chờ xác nhận" selected="@(Model.TrangThai == "Chờ xác nhận")">Chờ xác nhận</option>
                    <option value="Đã xác nhận" selected="@(Model.TrangThai == "Đã xác nhận")">Đã xác nhận</option>
                    <option value="Đã hủy" selected="@(Model.TrangThai == "Đã hủy")">Đã hủy</option>
                    <option value="Hoàn thành" selected="@(Model.TrangThai == "Hoàn thành")">Hoàn thành</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Ngày Nhận Phòng (Dự Kiến)</label>
                <input type="date" class="form-control" name="NgayNhanDuKien" value="@Model.NgayNhanDuKien:yyyy-MM-dd" required/>
            </div>

            <div class="form-group">
                <label class="form-label">Ngày Trả Phòng (Dự Kiến)</label>
                <input type="date" class="form-control" name="NgayTraDuKien" value="@Model.NgayTraDuKien:yyyy-MM-dd" required/>
            </div>

            <div class="form-group">
                <label class="form-label">Mã Khách Hàng</label>
                <input type="text" class="form-control" name="MaKhachHang" value="@Model.MaKhachHang" readonly style="background: #f8f9ff; cursor: not-allowed;"/>
                <small style="color: #757682; margin-top: 0.25rem; display: block;">Để thay đổi khách hàng, vui lòng xóa và tạo đơn mới</small>
            </div>

            <div style="display: flex; gap: 0.5rem; margin-top: 2rem;">
                <button type="submit" class="btn-submit">
                    <span class="material-icons" style="vertical-align: middle; margin-right: 0.5rem; font-size: 1.25rem;">save</span>
                    Lưu Thay Đổi
                </button>
                <a asp-action="Details" asp-route-id="@Model.MaDatPhong" class="btn-cancel" style="display: inline-flex; align-items: center;">
                    <span class="material-icons" style="margin-right: 0.5rem; font-size: 1.25rem;">close</span>
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>
