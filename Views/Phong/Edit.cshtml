@model WebKhachSan.Models.Phong

@{    Layout = "~/Views/Shared/_DashboardLayout.cshtml";    ViewData["Title"] = "Chỉnh sửa Phòng";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Phòng</a></li>
                    <li class="breadcrumb-item active">Chỉnh sửa</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-light border-bottom">
                    <h3 class="mb-0 fw-bold text-warning">
                        <i class="bi bi-pencil-square"></i> Chỉnh Sửa Phòng
                    </h3>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Mã Phòng</label>
                            <div class="form-control form-control-lg bg-light" disabled>
                                @Model.MaPhong
                            </div>
                            <input type="hidden" asp-for="MaPhong" />
                            <small class="text-muted d-block mt-1">Mã không thể thay đổi</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="SoPhong" class="form-label fw-bold">Số Phòng <span class="text-danger">*</span></label>
                            <input asp-for="SoPhong" class="form-control form-control-lg"
                                   aria-describedby="SoPhong-error" />
                            <span asp-validation-for="SoPhong" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="MaLoaiPhong" class="form-label fw-bold">Loại Phòng <span class="text-danger">*</span></label>
                            <select asp-for="MaLoaiPhong" class="form-select form-select-lg" aria-describedby="MaLoaiPhong-error">
                                <option value="">-- Chọn loại phòng --</option>
                                @foreach (var loaiPhong in ViewBag.LoaiPhongs)
                                {
                                    <option value="@loaiPhong.MaLoaiPhong" 
                                            selected="@(loaiPhong.MaLoaiPhong == Model.MaLoaiPhong ? "selected" : "")">
                                        @loaiPhong.TenLoaiPhong (@loaiPhong.SoNguoiToiDa người)
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="MaLoaiPhong" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TrangThai" class="form-label fw-bold">Trạng Thái</label>
                            <select asp-for="TrangThai" class="form-select form-select-lg" aria-describedby="TrangThai-error">
                                @foreach (var status in ViewBag.TrangThaiList)
                                {
                                    <option value="@status" selected="@(status == Model.TrangThai ? "selected" : "")">@status</option>
                                }
                            </select>
                            <span asp-validation-for="TrangThai" class="text-danger small mt-1"></span>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="bi bi-check-circle"></i> Cập Nhật
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
}
