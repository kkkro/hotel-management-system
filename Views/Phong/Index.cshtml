@model IEnumerable<WebKhachSan.Models.Phong>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Quản lý Phòng";
}

<div class="container-fluid py-4">
    <!-- Alert thông báo -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thành công!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold">Danh Sách Phòng</h2>
            <p class="text-muted">Quản lý các đơn vị vật lý riêng lẻ và trạng thái thời gian thực của chúng.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle"></i> Thêm phòng mới
        </a>
    </div>

    <!-- Bộ lọc trạng thái -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="btn-group" role="group">
                <a asp-action="Index" class="btn btn-outline-secondary @(ViewBag.CurrentFilter == null ? "active" : "")">
                    Tất cả phòng <span class="badge bg-secondary ms-1">@Model.Count()</span>
                </a>
                @foreach (var status in ViewBag.TrangThaiList)
                {
                    var count = Model.Count(p => p.TrangThai == status);
                    <a asp-action="Index" asp-route-trangThai="@status" 
                       class="btn btn-outline-secondary @(ViewBag.CurrentFilter == status ? "active" : "")">
                        @status <span class="badge bg-secondary ms-1">@count</span>
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Bảng danh sách -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 fw-bold text-uppercase text-muted small">Số Phòng</th>
                        <th class="fw-bold text-uppercase text-muted small">Loại</th>
                        <th class="text-center fw-bold text-uppercase text-muted small">Trạng Thái</th>
                        <th class="fw-bold text-uppercase text-muted small">Khách Tối Đa</th>
                        <th class="text-center fw-bold text-uppercase text-muted small">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count() > 0)
                    {
                        @foreach (var item in Model)
                        {
                            var badgeClass = item.TrangThai switch
                            {
                                "Trống" => "bg-success",
                                "Có khách" => "bg-warning",
                                "Bảo trì" => "bg-danger",
                                "Đã đặt" => "bg-info",
                                _ => "bg-secondary"
                            };

                            <tr>
                                <td class="ps-4 fw-semibold">@item.SoPhong</td>
                                <td>
                                    <span class="text-muted small">@item.MaLoaiPhongNavigation?.TenLoaiPhong</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @badgeClass">@item.TrangThai</span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">@item.MaLoaiPhongNavigation?.SoNguoiToiDa người</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@item.MaPhong" class="btn btn-outline-primary" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaPhong" class="btn btn-outline-warning" title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaPhong" class="btn btn-outline-danger" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                <p class="mt-3">Chưa có phòng nào</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
