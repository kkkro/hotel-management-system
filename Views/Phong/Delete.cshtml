@model WebKhachSan.Models.Phong

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Xoa Phong";

    var displayTrangThai = Model.TrangThai switch
    {
        "Tr?ng" or "Trá»‘ng" or "Trống" => "Trống",
        "Đang sử dụng" or "CÃ³ khÃ¡ch" or "Có khách" => "Đang sử dụng",
        "B?o trì" or "Báº£o trÃ¬" or "Bảo trì" => "Bảo trì",
        "Ðã d?t" or "ÄÃ£ Ä‘áº·t" or "Đã đặt" => "Đã đặt",
        _ => Model.TrangThai ?? string.Empty
    };

    var badgeClass = displayTrangThai switch
    {
        "Trống" => "bg-success",
        "Đang sử dụng" => "bg-warning",
        "Bảo trì" => "bg-danger",
        "Đã đặt" => "bg-info",
        _ => "bg-secondary"
    };
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chu</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Phong</a></li>
                    <li class="breadcrumb-item active">Xoa</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white border-bottom">
                    <h3 class="mb-0 fw-bold">
                        <i class="bi bi-exclamation-triangle"></i> Xac Nhan Xoa
                    </h3>
                </div>

                <div class="card-body p-4">
                    <div class="alert alert-warning mb-4">
                        <i class="bi bi-info-circle"></i> Ban chac chan muon xoa phong nay khong? Hanh dong nay khong the hoan tac.
                    </div>

                    <div class="info-box bg-light p-3 rounded mb-4">
                        <dl class="row">
                            <dt class="col-sm-4 fw-bold">Ma Phong:</dt>
                            <dd class="col-sm-8">@Model.MaPhong</dd>

                            <dt class="col-sm-4 fw-bold">So Phong:</dt>
                            <dd class="col-sm-8">@Model.SoPhong</dd>

                            <dt class="col-sm-4 fw-bold">Loai Phong:</dt>
                            <dd class="col-sm-8">@Model.MaLoaiPhongNavigation?.TenLoaiPhong</dd>

                            <dt class="col-sm-4 fw-bold">Trang Thai:</dt>
                            <dd class="col-sm-8">
                                <span class="badge @badgeClass">@displayTrangThai</span>
                            </dd>
                        </dl>
                    </div>

                    <form asp-action="Delete" method="post" class="mt-4">
                        <input type="hidden" asp-for="MaPhong" />

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash"></i> Xoa vinh vien
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Huy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
