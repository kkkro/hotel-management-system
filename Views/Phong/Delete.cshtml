@model WebKhachSan.Models.Phong

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Xóa Phòng";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Phòng</a></li>
                    <li class="breadcrumb-item active">Xóa</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white border-bottom">
                    <h3 class="mb-0 fw-bold">
                        <i class="bi bi-exclamation-triangle"></i> Xác Nhận Xóa
                    </h3>
                </div>
                
                <div class="card-body p-4">
                    <div class="alert alert-warning mb-4">
                        <i class="bi bi-info-circle"></i> Bạn chắc chắn muốn xóa phòng này không? Hành động này không thể được hoàn tác.
                    </div>

                    <div class="info-box bg-light p-3 rounded mb-4">
                        <dl class="row">
                            <dt class="col-sm-4 fw-bold">Mã Phòng:</dt>
                            <dd class="col-sm-8">@Model.MaPhong</dd>

                            <dt class="col-sm-4 fw-bold">Số Phòng:</dt>
                            <dd class="col-sm-8">@Model.SoPhong</dd>

                            <dt class="col-sm-4 fw-bold">Loại Phòng:</dt>
                            <dd class="col-sm-8">@Model.MaLoaiPhongNavigation?.TenLoaiPhong</dd>

                            <dt class="col-sm-4 fw-bold">Trạng Thái:</dt>
                            <dd class="col-sm-8">
                                @{
                                    var badgeClass = Model.TrangThai switch
                                    {
                                        "Trống" => "bg-success",
                                        "Có khách" => "bg-warning",
                                        "Bảo trì" => "bg-danger",
                                        "Đã đặt" => "bg-info",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@Model.TrangThai</span>
                            </dd>
                        </dl>
                    </div>

                    <form asp-action="Delete" method="post" class="mt-4">
                        <input type="hidden" asp-for="MaPhong" />
                        
                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash"></i> Xóa vĩnh viễn
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
