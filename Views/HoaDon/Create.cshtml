@model WebKhachSan.Models.HoaDon

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Tao Hoa Don";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light fw-bold">Tao hoa don</div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="MaHoaDon" class="form-label"></label>
                            <input asp-for="MaHoaDon" class="form-control" />
                            <span asp-validation-for="MaHoaDon" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MaNhanVien" class="form-label"></label>
                            <select asp-for="MaNhanVien" class="form-select">
                                <option value="">-- Chon nhan vien --</option>
                                @if (ViewBag.NhanViens != null)
                                {
                                    @foreach (var nv in ViewBag.NhanViens)
                                    {
                                        <option value="@nv.MaNhanVien">@nv.TenNhanVien</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="MaNhanVien" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NgayLap" class="form-label"></label>
                            <input asp-for="NgayLap" type="date" class="form-control" />
                            <span asp-validation-for="NgayLap" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TongTien" class="form-label"></label>
                            <input asp-for="TongTien" class="form-control" />
                            <span asp-validation-for="TongTien" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Luu</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Huy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
