@model WebKhachSan.Models.HoaDon

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Xoa Hoa Don";
    var firstDetail = Model.CthoaDons.FirstOrDefault();
    var customer = firstDetail?.MaThuePhongNavigation?.MaKhachHangNavigation;
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white fw-bold">Xoa hoa don</div>
                <div class="card-body">
                    <p class="text-muted">Ban chac chan muon xoa hoa don nay?</p>

                    <dl class="row">
                        <dt class="col-sm-4">Ma hoa don</dt>
                        <dd class="col-sm-8">@Model.MaHoaDon</dd>

                        <dt class="col-sm-4">Khach hang</dt>
                        <dd class="col-sm-8">@(customer?.TenKhachHang ?? "Khong xac dinh")</dd>

                        <dt class="col-sm-4">Nhan vien lap</dt>
                        <dd class="col-sm-8">@(Model.MaNhanVienNavigation?.TenNhanVien ?? "----")</dd>

                        <dt class="col-sm-4">Tong tien</dt>
                        <dd class="col-sm-8">@((Model.TongTien ?? 0).ToString("N0")) VND</dd>
                    </dl>

                    <form asp-action="Delete" method="post" class="d-flex gap-2">
                        <input type="hidden" asp-for="MaHoaDon" />
                        <button type="submit" class="btn btn-danger">Xoa</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Huy</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
