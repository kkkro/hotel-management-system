@model IEnumerable<WebKhachSan.Models.HoaDon>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Hoa Don";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold">Danh sach hoa don</h2>
            <p class="text-muted mb-0">Thong tin hoa don va chi tiet thanh toan.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">Tao hoa don moi</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Ma hoa don</th>
                        <th>Khach hang</th>
                        <th>Nhan vien</th>
                        <th>Ngay lap</th>
                        <th class="text-end">Tong tien</th>
                        <th class="text-center">Thao tac</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            var firstDetail = item.CthoaDons.FirstOrDefault();
                            var customer = firstDetail?.MaThuePhongNavigation?.MaKhachHangNavigation;

                            <tr>
                                <td class="ps-4 fw-semibold text-primary">@item.MaHoaDon</td>
                                <td>
                                    <div class="fw-semibold">@(customer?.TenKhachHang ?? "Khong xac dinh")</div>
                                    <small class="text-muted">@customer?.DienThoai</small>
                                </td>
                                <td>@(item.MaNhanVienNavigation?.TenNhanVien ?? "----")</td>
                                <td>@item.NgayLap?.ToString("dd/MM/yyyy")</td>
                                <td class="text-end fw-semibold">@((item.TongTien ?? 0).ToString("N0")) VND</td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@item.MaHoaDon" class="btn btn-outline-primary">Xem</a>
                                        <a asp-action="Edit" asp-route-id="@item.MaHoaDon" class="btn btn-outline-warning">Sua</a>
                                        <a asp-action="Delete" asp-route-id="@item.MaHoaDon" class="btn btn-outline-danger">Xoa</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">Chua co hoa don nao.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
