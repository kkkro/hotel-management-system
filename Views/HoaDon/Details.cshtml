@model WebKhachSan.Models.HoaDon

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Chi Tiet Hoa Don";
    var firstDetail = Model.CthoaDons.FirstOrDefault();
    var customer = firstDetail?.MaThuePhongNavigation?.MaKhachHangNavigation;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold">Chi tiet hoa don</h2>
            <p class="text-muted mb-0">@Model.MaHoaDon</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lai</a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="text-muted small">Ma hoa don</div>
                    <div class="fw-bold">@Model.MaHoaDon</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Ngay lap</div>
                    <div>@Model.NgayLap?.ToString("dd/MM/yyyy")</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Khach hang</div>
                    <div class="fw-semibold">@(customer?.TenKhachHang ?? "Khong xac dinh")</div>
                    <div class="text-muted small">@customer?.DienThoai</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Nhan vien lap</div>
                    <div>@(Model.MaNhanVienNavigation?.TenNhanVien ?? "----")</div>
                </div>
                <div class="col-12">
                    <div class="text-muted small">Tong tien</div>
                    <div class="fw-bold fs-4 text-primary">@((Model.TongTien ?? 0).ToString("N0")) VND</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-light fw-bold">Chi tiet hoa don</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Ma thue phong</th>
                            <th>Noi dung</th>
                            <th class="text-end pe-3">So tien</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var chi in Model.CthoaDons)
                        {
                            <tr>
                                <td class="ps-3">@chi.MaThuePhong</td>
                                <td>@chi.NoiDung</td>
                                <td class="text-end pe-3">@((chi.SoTien ?? 0).ToString("N0")) VND</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
