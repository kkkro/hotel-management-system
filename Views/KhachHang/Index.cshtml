@model IEnumerable<WebKhachSan.Models.KhachHang>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="container-fluid py-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thành công!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold">Khách hàng</h2>
            <p class="text-muted">Quản lý thông tin và lịch sử khách hàng của khách sạn</p>
        </div>
    </div>

    <!-- Form Tìm Kiếm -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-9">
                    <input type="text" 
                           name="searchTerm" 
                           class="form-control" 
                           placeholder="Tìm kiếm theo mã, tên, điện thoại, CCCD, địa chỉ..." 
                           value="@ViewBag.SearchTerm" />
                </div>
                <div class="col-md-3">
                    <div class="btn-group w-100" role="group">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> Tìm kiếm
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-clockwise"></i> Xóa
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Kết quả tìm kiếm -->
    @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle"></i> Kết quả tìm kiếm cho: <strong>@ViewBag.SearchTerm</strong> 
            (@Model.Count() khách hàng)
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header bg-light border-bottom">
            <span class="text-muted">
                <i class="bi bi-people"></i>
                Tổng cộng: <strong>@Model.Count()</strong> khách hàng
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 fw-bold text-uppercase text-muted small">Mã KH</th>
                        <th class="fw-bold text-uppercase text-muted small">Tên khách hàng</th>
                        <th class="fw-bold text-uppercase text-muted small">Điện thoại</th>
                        <th class="fw-bold text-uppercase text-muted small">Địa chỉ</th>
                        <th class="fw-bold text-uppercase text-muted small">CCCD</th>
                        <th class="text-center fw-bold text-uppercase text-muted small">Lượt thuê</th>
                        <th class="text-center fw-bold text-uppercase text-muted small">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-primary">@item.MaKhachHang</td>
                                <td class="fw-semibold">@item.TenKhachHang</td>
                                <td>@item.DienThoai</td>
                                <td class="text-muted small" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @item.DiaChi
                                </td>
                                <td>@item.Cccd</td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark">@(item.ThuePhongs?.Count ?? 0)</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@item.MaKhachHang" class="btn btn-outline-primary" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaKhachHang" class="btn btn-outline-warning" title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaKhachHang" class="btn btn-outline-danger" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm))
                                {
                                    <p class="mt-3">Không tìm thấy khách hàng nào với từ khóa: <strong>@ViewBag.SearchTerm</strong></p>
                                }
                                else
                                {
                                    <p class="mt-3">Chưa có khách hàng nào</p>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
