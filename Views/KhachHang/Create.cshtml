@model WebKhachSan.Models.KhachHang

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Them Khach Hang";
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chu</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Khach hang</a></li>
            <li class="breadcrumb-item active" aria-current="page">Them moi</li>
        </ol>
    </nav>

    <div class="mb-4">
        <h2 class="mb-1 fw-bold">Them Khach Hang Moi</h2>
        <p class="text-muted">Nhap thong tin khach hang vao form ben duoi</p>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div class="mb-3">
                            <label asp-for="MaKhachHang" class="form-label fw-semibold">Ma Khach Hang</label>
                            <input asp-for="MaKhachHang" class="form-control" placeholder="VD: KH001" />
                            <span asp-validation-for="MaKhachHang" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TenKhachHang" class="form-label fw-semibold">Ten Khach Hang</label>
                            <input asp-for="TenKhachHang" class="form-control" placeholder="Nhap ten khach hang" />
                            <span asp-validation-for="TenKhachHang" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="DienThoai" class="form-label fw-semibold">Dien Thoai</label>
                                    <input asp-for="DienThoai" type="tel" class="form-control" placeholder="VD: 0912345678" />
                                    <span asp-validation-for="DienThoai" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                                    <input asp-for="Email" type="email" class="form-control" placeholder="VD: ten@khachsan.com" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Cccd" class="form-label fw-semibold">CCCD</label>
                                    <input asp-for="Cccd" class="form-control" placeholder="Nhap so CCCD" />
                                    <span asp-validation-for="Cccd" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiaChi" class="form-label fw-semibold">Dia Chi</label>
                            <textarea asp-for="DiaChi" class="form-control" rows="3" placeholder="Nhap dia chi day du"></textarea>
                            <span asp-validation-for="DiaChi" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 pt-3">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-circle"></i> Luu
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-x-circle"></i> Huy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 bg-light mb-3">
                <div class="card-body">
                    <h6 class="card-title fw-bold">
                        <i class="bi bi-info-circle"></i> Luu y
                    </h6>
                    <ul class="small list-unstyled">
                        <li><i class="bi bi-check-circle text-success"></i> <span class="ms-2">Ma khach hang phai la duy nhat</span></li>
                        <li><i class="bi bi-check-circle text-success"></i> <span class="ms-2">CCCD cung phai la duy nhat</span></li>
                        <li><i class="bi bi-check-circle text-success"></i> <span class="ms-2">Ten khach hang la bat buoc</span></li>
                        <li><i class="bi bi-check-circle text-success"></i> <span class="ms-2">Email giup lien he va xac nhan de dang hon</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
