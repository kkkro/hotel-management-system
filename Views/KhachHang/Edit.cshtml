@model WebKhachSan.Models.KhachHang

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Chinh Sua Khach Hang";
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chu</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Khach hang</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chinh sua</li>
        </ol>
    </nav>

    <div class="mb-4">
        <h2 class="mb-1 fw-bold">Chinh Sua Thong Tin Khach Hang</h2>
        <p class="text-muted">Cap nhat thong tin cho khach hang <strong>@Model?.TenKhachHang</strong></p>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="MaKhachHang" />

                        <div class="mb-3">
                            <label asp-for="MaKhachHang" class="form-label fw-semibold">Ma Khach Hang</label>
                            <div class="input-group">
                                <input asp-for="MaKhachHang" class="form-control bg-light" readonly />
                                <span class="input-group-text bg-light" title="Ma khach hang khong the thay doi">
                                    <i class="bi bi-lock"></i>
                                </span>
                            </div>
                            <small class="text-muted">Ma khach hang khong the thay doi</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TenKhachHang" class="form-label fw-semibold">Ten Khach Hang</label>
                            <input asp-for="TenKhachHang" class="form-control" placeholder="Nhap ten khach hang" />
                            <span asp-validation-for="TenKhachHang" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="DienThoai" class="form-label fw-semibold">Dien Thoai</label>
                                    <input asp-for="DienThoai" type="tel" class="form-control" placeholder="VD: 0912345678" />
                                    <span asp-validation-for="DienThoai" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                                    <input asp-for="Email" type="email" class="form-control" placeholder="VD: ten@khachsan.com" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Cccd" class="form-label fw-semibold">CCCD</label>
                                    <input asp-for="Cccd" class="form-control" placeholder="Nhap so CCCD" />
                                    <span asp-validation-for="Cccd" class="text-danger small"></span>
                                    <small class="text-warning d-block mt-2">
                                        <i class="bi bi-exclamation-triangle"></i> CCCD phai la duy nhat trong he thong
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiaChi" class="form-label fw-semibold">Dia Chi</label>
                            <textarea asp-for="DiaChi" class="form-control" rows="3" placeholder="Nhap dia chi day du"></textarea>
                            <span asp-validation-for="DiaChi" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 pt-3">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-circle"></i> Cap Nhat
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-x-circle"></i> Huy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 bg-light mb-3">
                <div class="card-body">
                    <h6 class="card-title fw-bold">
                        <i class="bi bi-info-circle"></i> Thong Tin
                    </h6>
                    <ul class="small list-unstyled">
                        <li><i class="bi bi-lock"></i> <span class="ms-2">Ma khach khong the thay doi</span></li>
                        <li><i class="bi bi-check-circle text-warning"></i> <span class="ms-2">CCCD phai duy nhat</span></li>
                        <li><i class="bi bi-envelope"></i> <span class="ms-2">Email giup lien he va gui xac nhan</span></li>
                    </ul>
                </div>
            </div>

            @if (Model?.ThuePhongs?.Count > 0)
            {
                <div class="card border-0 bg-info bg-opacity-10 text-info">
                    <div class="card-body">
                        <h6 class="card-title fw-bold">
                            <i class="bi bi-graph-up"></i> Lich Su
                        </h6>
                        <p class="mb-0">
                            <strong>@Model.ThuePhongs.Count</strong> lan thue
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
