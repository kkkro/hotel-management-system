@model WebKhachSan.Models.KhachHang

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Xóa Khách Hàng";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Khách hàng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Xóa</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h2 class="mb-1 fw-bold">Xóa Khách Hàng</h2>
        <p class="text-muted">Xác nhận xóa khách hàng khỏi hệ thống</p>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 border-danger border-3">
                <div class="card-body p-4">
                    <div class="alert alert-danger d-flex gap-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size: 1.5rem;"></i>
                        <div>
                            <strong>Cảnh báo!</strong> Hành động này không thể được hoàn tác. Vui lòng xác nhận trước khi xóa.
                        </div>
                    </div>

                    <!-- Thông tin khách hàng -->
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3">Thông Tin Khách Hàng</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="text-muted small">Mã Khách Hàng</div>
                                <div class="fw-semibold">@Model?.MaKhachHang</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="text-muted small">Tên Khách Hàng</div>
                                <div class="fw-semibold">@Model?.TenKhachHang</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="text-muted small">Điện Thoại</div>
                                <div class="fw-semibold">@Model?.DienThoai</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="text-muted small">CCCD</div>
                                <div class="fw-semibold">@Model?.Cccd</div>
                            </div>
                            <div class="col-12 mb-3">
                                <div class="text-muted small">Địa Chỉ</div>
                                <div class="fw-semibold">@Model?.DiaChi</div>
                            </div>
                        </div>
                    </div>

                    <!-- Kiểm tra lịch sử -->
                    @if (Model?.ThuePhongs?.Count > 0 || Model?.DatPhongs?.Count > 0)
                    {
                        <div class="alert alert-warning d-flex gap-3" role="alert">
                            <i class="bi bi-info-circle-fill" style="font-size: 1.5rem;"></i>
                            <div>
                                <strong>Không thể xóa!</strong> Khách hàng này có lịch sử thuê phòng hoặc đặt phòng.
                                <ul class="mb-0 mt-2 small">
                                    <li>Số lần thuê: <strong>@(Model?.ThuePhongs?.Count ?? 0)</strong></li>
                                    <li>Số lần đặt: <strong>@(Model?.DatPhongs?.Count ?? 0)</strong></li>
                                </ul>
                            </div>
                        </div>

                        <div class="d-flex gap-2 pt-3">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left"></i> Quay Lại
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info d-flex gap-3" role="alert">
                            <i class="bi bi-check-circle-fill" style="font-size: 1.5rem;"></i>
                            <div>
                                Khách hàng này không có lịch sử thuê hoặc đặt phòng, có thể xóa an toàn.
                            </div>
                        </div>

                        <!-- Form xác nhận xóa -->
                        <form asp-action="DeleteConfirmed" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@Model?.MaKhachHang" />

                            <div class="d-flex gap-2 pt-3">
                                <button type="submit" class="btn btn-danger px-4">
                                    <i class="bi bi-trash"></i> Xác Nhận Xóa
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                    <i class="bi bi-x-circle"></i> Hủy
                                </a>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>

        <!-- Info Panel -->
        <div class="col-lg-4">
            <div class="card border-0 bg-danger bg-opacity-10 text-danger">
                <div class="card-body">
                    <h6 class="card-title fw-bold">
                        <i class="bi bi-exclamation-triangle"></i> Hậu Quả Xóa
                    </h6>
                    <ul class="small list-unstyled">
                        <li><i class="bi bi-x-circle"></i> <span class="ms-2">Dữ liệu sẽ được xóa vĩnh viễn</span></li>
                        <li><i class="bi bi-x-circle"></i> <span class="ms-2">Không thể phục hồi được</span></li>
                        <li><i class="bi bi-x-circle"></i> <span class="ms-2">Hãy sao lưu trước khi xóa</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
