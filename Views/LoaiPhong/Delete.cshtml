@model WebKhachSan.Models.LoaiPhong

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Xóa Loại Phòng";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Loại Phòng</a></li>
                    <li class="breadcrumb-item active">Xóa</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white border-bottom">
                    <h3 class="mb-0 fw-bold">
                        <i class="bi bi-exclamation-triangle"></i> Xác Nhận Xóa
                    </h3>
                </div>
                
                <div class="card-body p-4">
                    <div class="alert alert-warning mb-4">
                        <i class="bi bi-info-circle"></i> Bạn chắc chắn muốn xóa loại phòng này không? Hành động này không thể được hoàn tác.
                    </div>

                    <div class="info-box bg-light p-3 rounded mb-4">
                        <dl class="row">
                            <dt class="col-sm-4 fw-bold">Mã Loại:</dt>
                            <dd class="col-sm-8">@Model.MaLoaiPhong</dd>

                            <dt class="col-sm-4 fw-bold">Tên Loại:</dt>
                            <dd class="col-sm-8">@Model.TenLoaiPhong</dd>

                            <dt class="col-sm-4 fw-bold">Mô Tả:</dt>
                            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.MoTa) ? "(Không có)" : Model.MoTa)</dd>

                            <dt class="col-sm-4 fw-bold">Khách Tối Đa:</dt>
                            <dd class="col-sm-8">@Model.SoNguoiToiDa người</dd>

                            <dt class="col-sm-4 fw-bold">Số Phòng:</dt>
                            <dd class="col-sm-8">
                                @if (Model.Phongs != null)
                                {
                                    <span class="badge bg-info">@Model.Phongs.Count phòng</span>
                                }
                            </dd>
                        </dl>
                    </div>

                    @if (Model.Phongs != null && Model.Phongs.Count > 0)
                    {
                        <div class="alert alert-danger">
                            <strong><i class="bi bi-exclamation-circle"></i> Cảnh báo:</strong> Còn <strong>@Model.Phongs.Count</strong> phòng đang sử dụng loại phòng này. Xóa loại phòng có thể ảnh hưởng đến các phòng này.
                        </div>
                    }

                    <form asp-action="Delete" method="post" class="mt-4">
                        <input type="hidden" asp-for="MaLoaiPhong" />
                        
                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash"></i> Xóa vĩnh viễn
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
