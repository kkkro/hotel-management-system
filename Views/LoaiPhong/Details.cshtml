@model WebKhachSan.Models.LoaiPhong

@{    Layout = "~/Views/Shared/_DashboardLayout.cshtml";    ViewData["Title"] = "Chi Tiết Loại Phòng";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Loại Phòng</a></li>
                    <li class="breadcrumb-item active">Chi tiết</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-light border-bottom">
                    <h3 class="mb-0 fw-bold text-info">
                        <i class="bi bi-info-circle"></i> Chi Tiết Loại Phòng
                    </h3>
                </div>
                
                <div class="card-body p-4">
                    <dl class="row mb-4">
                        <dt class="col-sm-3 fw-bold">Mã Loại:</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-primary">@Model.MaLoaiPhong</span>
                        </dd>

                        <dt class="col-sm-3 fw-bold">Tên Loại:</dt>
                        <dd class="col-sm-9">@Model.TenLoaiPhong</dd>

                        <dt class="col-sm-3 fw-bold">Mô Tả:</dt>
                        <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.MoTa) ? "(Không có)" : Model.MoTa)</dd>

                        <dt class="col-sm-3 fw-bold">Khách Tối Đa:</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-success" style="font-size: 14px;">@Model.SoNguoiToiDa người</span>
                        </dd>
                    </dl>

                    <hr />

                    <!-- Danh sách phòng -->
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-door-closed"></i> Phòng Loại Này
                        <span class="badge bg-info">@(Model.Phongs?.Count ?? 0)</span>
                    </h5>
                    
                    @if (Model.Phongs != null && Model.Phongs.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Mã Phòng</th>
                                        <th>Số Phòng</th>
                                        <th>Trạng Thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var phong in Model.Phongs)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@phong.MaPhong</td>
                                            <td>@phong.SoPhong</td>
                                            <td>
                                                @{
                                                    var badgeClass = phong.TrangThai switch
                                                    {
                                                        "Trống" => "bg-success",
                                                        "Có khách" => "bg-warning",
                                                        "Bảo trì" => "bg-danger",
                                                        "Đã đặt" => "bg-info",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @badgeClass">@phong.TrangThai</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">
                            <i class="bi bi-inbox"></i> Chưa có phòng nào loại này
                        </p>
                    }

                    <hr />

                    <!-- Danh sách giá -->
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-tag"></i> Giá Phòng
                        <span class="badge bg-info">@(Model.GiaPhongs?.Count ?? 0)</span>
                    </h5>
                    
                    @if (Model.GiaPhongs != null && Model.GiaPhongs.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Mã Giá</th>
                                        <th>Giá (VND)</th>
                                        <th>Ngày Bắt Đầu</th>
                                        <th>Ngày Kết Thúc</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var gia in Model.GiaPhongs)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@gia.MaGia</td>
                                            <td class="text-end fw-bold">@gia.Gia?.ToString("N0")</td>
                                            <td>@gia.NgayBatDau?.ToString("dd/MM/yyyy")</td>
                                            <td>@(gia.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "(Không giới hạn)")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">
                            <i class="bi bi-inbox"></i> Chưa có giá nào được thiết lập
                        </p>
                    }

                    <div class="d-flex gap-3 mt-4">
                        <a asp-action="Edit" asp-route-id="@Model.MaLoaiPhong" class="btn btn-warning">
                            <i class="bi bi-pencil"></i> Chỉnh Sửa
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.MaLoaiPhong" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Xóa
                        </a>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Quay Lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
