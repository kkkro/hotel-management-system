@model WebKhachSan.Models.LoaiPhong

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Thêm Loại Phòng Mới";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Loại Phòng</a></li>
                    <li class="breadcrumb-item active">Thêm mới</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-light border-bottom">
                    <h3 class="mb-0 fw-bold text-primary">
                        <i class="bi bi-plus-circle"></i> Thêm Loại Phòng Mới
                    </h3>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-4">
                            <label asp-for="MaLoaiPhong" class="form-label fw-bold">Mã Loại Phòng <span class="text-danger">*</span></label>
                            <input asp-for="MaLoaiPhong" class="form-control form-control-lg" placeholder="VD: LP001" 
                                   aria-describedby="MaLoaiPhong-error" />
                            <span asp-validation-for="MaLoaiPhong" class="text-danger small mt-1"></span>
                            <small class="text-muted d-block mt-1">Mã định danh duy nhất cho loại phòng (VD: LP001, LP002)</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TenLoaiPhong" class="form-label fw-bold">Tên Loại Phòng <span class="text-danger">*</span></label>
                            <input asp-for="TenLoaiPhong" class="form-control form-control-lg" placeholder="VD: Phòng Suite Cao Cấp"
                                   aria-describedby="TenLoaiPhong-error" />
                            <span asp-validation-for="TenLoaiPhong" class="text-danger small mt-1"></span>
                            <small class="text-muted d-block mt-1">Tên gọi của loại phòng</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="MoTa" class="form-label fw-bold">Mô Tả</label>
                            <textarea asp-for="MoTa" class="form-control" rows="4" 
                                      placeholder="Nhập mô tả chi tiết về loại phòng này"
                                      aria-describedby="MoTa-error"></textarea>
                            <span asp-validation-for="MoTa" class="text-danger small mt-1"></span>
                            <small class="text-muted d-block mt-1">Mô tả đặc điểm, tiện nghi của loại phòng</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="SoNguoiToiDa" class="form-label fw-bold">Số Người Tối Đa <span class="text-danger">*</span></label>
                            <input asp-for="SoNguoiToiDa" type="number" class="form-control form-control-lg" placeholder="VD: 2, 4, 6"
                                   aria-describedby="SoNguoiToiDa-error" />
                            <span asp-validation-for="SoNguoiToiDa" class="text-danger small mt-1"></span>
                            <small class="text-muted d-block mt-1">Sức chứa tối đa của loại phòng</small>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle"></i> Thêm Loại Phòng
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
}
