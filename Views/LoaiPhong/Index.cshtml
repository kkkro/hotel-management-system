@using System.Collections.Generic
@using WebKhachSan.Models

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Quản lý Loại Phòng";
}

<div class="container-fluid py-4">
    <!-- Alert thông báo -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thành công!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold">Loại Phòng</h2>
            <p class="text-muted">Xác định các hạng mục phòng của khách sạn và các thuộc tính cốt lõi của chúng.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle"></i> Thêm loại mới
        </a>
    </div>

    <!-- Bảng danh sách -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 fw-bold text-uppercase text-muted small">Mã Loại</th>
                        <th class="fw-bold text-uppercase text-muted small">Tên Loại</th>
                        <th class="fw-bold text-uppercase text-muted small">Mô Tả</th>
                        <th class="text-center fw-bold text-uppercase text-muted small">Khách Tối Đa</th>
                        <th class="text-end fw-bold text-uppercase text-muted small">Giá Hiện Tại</th>
                        <th class="text-center fw-bold text-uppercase text-muted small">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            var currentPrice = ((IEnumerable<GiaPhong>)item.GiaPhongs)?
                                .Where(g => g.NgayBatDau <= DateTime.Now && 
                                           (g.NgayKetThuc == null || g.NgayKetThuc >= DateTime.Now))
                                .OrderByDescending(g => g.NgayBatDau)
                                .FirstOrDefault();
                            
                            <tr>
                                <td class="ps-4 fw-semibold text-primary">@item.MaLoaiPhong</td>
                                <td class="fw-semibold">@item.TenLoaiPhong</td>
                                <td class="text-muted small" style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @item.MoTa
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark">@item.SoNguoiToiDa</span>
                                </td>
                                <td class="text-end fw-semibold text-success">
                                    @if (currentPrice != null)
                                    {
                                        @currentPrice.Gia?.ToString("N0") <span class="text-muted small">VND</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Chưa có giá</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@item.MaLoaiPhong" class="btn btn-outline-primary" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-info" title="Xem giá" onclick="viewGiaPhong('@item.MaLoaiPhong', '@item.TenLoaiPhong')">
                                            <i class="bi bi-tag"></i>
                                        </button>
                                        <a asp-action="Edit" asp-route-id="@item.MaLoaiPhong" class="btn btn-outline-warning" title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaLoaiPhong" class="btn btn-outline-danger" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                <p class="mt-3">Chưa có loại phòng nào</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal hiển thị bảng giá -->
<div class="modal fade" id="modalGiaPhong" tabindex="-1" aria-labelledby="modalGiaPhongLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalGiaPhongLabel">
                    Bảng Giá: <strong id="tenLoaiPhong"></strong>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="giaPhongContent">
                    <div class="text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Đang tải...</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <a href="#" id="addPriceBtn" class="btn btn-primary" target="_self">
                    <i class="bi bi-plus-circle"></i> Thêm giá mới
                </a>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">

<script>
function viewGiaPhong(maLoaiPhong, tenLoaiPhong) {
    document.getElementById('tenLoaiPhong').textContent = tenLoaiPhong;
    document.getElementById('addPriceBtn').href = `/GiaPhong/Create?maLoaiPhong=${maLoaiPhong}`;
    
    const contentDiv = document.getElementById('giaPhongContent');
    contentDiv.innerHTML = '<div class="text-center"><div class="spinner-border" role="status"><span class="visually-hidden">Đang tải...</span></div></div>';
    
    fetch(`/LoaiPhong/GetDanhSachGia?maLoaiPhong=${maLoaiPhong}`)
        .then(response => response.json())
        .then(data => {
            if (!data || data.length === 0) {
                contentDiv.innerHTML = '<div class="alert alert-info">Chưa có bảng giá nào</div>';
                return;
            }
            
            let html = '<div class="table-responsive"><table class="table table-sm">';
            html += '<thead class="table-light"><tr>';
            html += '<th>Mã Giá</th>';
            html += '<th class="text-end">Giá (VND)</th>';
            html += '<th>Ngày Bắt Đầu</th>';
            html += '<th>Ngày Kết Thúc</th>';
            html += '<th class="text-center">Trạng Thái</th>';
            html += '</tr></thead><tbody>';
            
            data.forEach(item => {
                const isActive = new Date(item.ngayBatDau) <= new Date() && 
                                (item.ngayKetThuc === null || new Date(item.ngayKetThuc) >= new Date());
                const statusClass = isActive ? 'bg-success' : 'bg-danger';
                const statusText = isActive ? 'Đang áp dụng' : 'Hết hạn';
                
                html += '<tr>';
                html += `<td class="fw-semibold">${item.maGia}</td>`;
                html += `<td class="text-end">${item.gia?.toLocaleString('vi-VN')}</td>`;
                html += `<td>${new Date(item.ngayBatDau).toLocaleDateString('vi-VN')}</td>`;
                html += `<td>${item.ngayKetThuc ? new Date(item.ngayKetThuc).toLocaleDateString('vi-VN') : '(Không giới hạn)'}</td>`;
                html += `<td class="text-center"><span class="badge ${statusClass}">${statusText}</span></td>`;
                html += '</tr>';
            });
            
            html += '</tbody></table></div>';
            contentDiv.innerHTML = html;
        })
        .catch(error => {
            console.error('Error:', error);
            contentDiv.innerHTML = '<div class="alert alert-danger">Lỗi khi tải dữ liệu</div>';
        });
    
    new bootstrap.Modal(document.getElementById('modalGiaPhong')).show();
}
</script>
