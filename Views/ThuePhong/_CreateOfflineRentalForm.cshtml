@model ThuePhongOfflineViewModel

<form id="offlineRentalForm" method="post" asp-controller="ThuePhong" asp-action="CreateOffline" novalidate>
    @Html.AntiForgeryToken()
    <input asp-for="MaPhong" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="card border-0 bg-light mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase">Phòng</div>
                    <div class="fw-bold fs-5">@Model.SoPhong</div>
                    <small class="text-muted">@Model.MaPhong</small>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase">Loại phòng</div>
                    <div class="fw-semibold">@Model.TenLoaiPhong</div>
                </div>
                <div class="col-md-4 text-md-end">
                    <div class="text-muted small text-uppercase">Giá hiện tại</div>
                    <div class="fw-bold text-success">@(Model.GiaHienTai?.ToString("N0") ?? "0") VND</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="TenKhachHang" class="form-label fw-semibold">Tên khách hàng</label>
            <input asp-for="TenKhachHang" class="form-control" placeholder="Nguyễn Văn A" maxlength="100" />
            <span asp-validation-for="TenKhachHang" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="DienThoai" class="form-label fw-semibold">Điện thoại</label>
            <input asp-for="DienThoai" class="form-control" placeholder="0901234567" maxlength="15" />
            <span asp-validation-for="DienThoai" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Cccd" class="form-label fw-semibold">CCCD</label>
            <input asp-for="Cccd" class="form-control" placeholder="Tùy chọn" inputmode="numeric" maxlength="12" />
            <span asp-validation-for="Cccd" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="NgayNhan" class="form-label fw-semibold">Ngày nhận phòng</label>
            <input asp-for="NgayNhan" type="date" class="form-control" />
            <span asp-validation-for="NgayNhan" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="NgayTra" class="form-label fw-semibold">Ngày trả phòng</label>
            <input asp-for="NgayTra" type="date" class="form-control" />
            <span asp-validation-for="NgayTra" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label asp-for="DiaChi" class="form-label fw-semibold">Địa chỉ</label>
            <textarea asp-for="DiaChi" class="form-control" rows="2" placeholder="Địa chỉ hiện tại của khách" maxlength="255"></textarea>
            <span asp-validation-for="DiaChi" class="text-danger small"></span>
        </div>
    </div>

    <div class="alert alert-info mt-4 mb-0">
        Nếu CCCD đã tồn tại trong hệ thống, hệ thống sẽ cập nhật lại thông tin khách và lập phiếu thuê mới cho phòng này.
    </div>
</form>
