@model IEnumerable<WebKhachSan.Models.ThuePhong>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Thue phong";
}

<div class="container-fluid py-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thanh cong!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold">Phieu thue phong</h2>
            <p class="text-muted mb-0">Quan ly danh sach khach thue offline tai quay le tan.</p>
        </div>
        <button type="button" class="btn btn-primary js-thue-phong-moi">
            <i class="bi bi-plus-circle"></i> Thue phong moi
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Ma thue</th>
                        <th>Khach hang</th>
                        <th>Phong</th>
                        <th>Ngay nhan</th>
                        <th>Ngay tra</th>
                        <th class="text-end">Gia thue</th>
                        <th class="text-center">Trang thai</th>
                        <th class="text-center">Thao tac</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            var chiTiet = item.CtthuePhongs.FirstOrDefault();
                            var rawTrangThai = string.IsNullOrWhiteSpace(item.TrangThai)
                                ? (item.NgayTra.HasValue ? "Da tra" : "Dang thue")
                                : item.TrangThai.Trim();
                            var displayTrangThai = rawTrangThai switch
                            {
                                "Dang thue" or "Đang thuê" or "Äang thuÃª" => "Dang thue",
                                "Da tra" or "Đã trả" or "ÄÃ£ tráº£" => "Da tra",
                                _ => rawTrangThai
                            };
                            var badgeClass = displayTrangThai switch
                            {
                                "Dang thue" => "bg-success",
                                "Da tra" => "bg-secondary",
                                _ => "bg-primary"
                            };
                            var isDangThue = displayTrangThai == "Dang thue";

                            <tr>
                                <td class="ps-4 fw-semibold text-primary">@item.MaThuePhong</td>
                                <td>
                                    <div class="fw-semibold">@item.MaKhachHangNavigation?.TenKhachHang</div>
                                    <small class="text-muted">@item.MaKhachHangNavigation?.DienThoai</small>
                                </td>
                                <td>
                                    <div class="fw-semibold">@chiTiet?.MaPhongNavigation?.SoPhong</div>
                                    <small class="text-muted">@chiTiet?.MaPhongNavigation?.MaLoaiPhongNavigation?.TenLoaiPhong</small>
                                </td>
                                <td>@item.NgayNhan?.ToString("dd/MM/yyyy")</td>
                                <td>@(item.NgayTra?.ToString("dd/MM/yyyy") ?? "Chua tra")</td>
                                <td class="text-end">@chiTiet?.GiaThueTaiThoiDiem?.ToString("N0")</td>
                                <td class="text-center">
                                    <span class="badge @badgeClass">@displayTrangThai</span>
                                </td>
                                <td class="text-center">
                                    @if (isDangThue)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger js-tra-phong" data-id="@item.MaThuePhong">
                                            <i class="bi bi-box-arrow-left"></i> Tra phong
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                <p class="mt-3 mb-0">Chua co phieu thue phong nao.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="thuePhongModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thue Phong Moi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4" id="thuePhongModalBody"></div>
            <div class="modal-footer" id="thuePhongModalFooter"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="traPhongModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Tra Phong</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="traPhongModalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huy</button>
                <button type="button" class="btn btn-danger" id="btnConfirmTraPhong">
                    <i class="bi bi-check-circle"></i> Xac nhan tra phong
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var thuePhongModal;
            var traPhongModal;

            $(document).on('click', '.js-thue-phong-moi', function () {
                $.get('/ThuePhong/CreateStep1', function (html) {
                    $('#thuePhongModalBody').html(html);
                    $('#thuePhongModalFooter').html(
                        '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huy</button>' +
                        '<button type="button" class="btn btn-primary" id="btnStep1Next">Tiep tuc <i class="bi bi-arrow-right"></i></button>'
                    );
                    thuePhongModal = new bootstrap.Modal($('#thuePhongModal'));
                    thuePhongModal.show();
                });
            });

            $(document).on('click', '#btnStep1Next', function () {
                var form = $('#createStep1Form');
                $.ajax({
                    url: '/ThuePhong/CreateStep1',
                    type: 'POST',
                    data: form.serialize(),
                    success: function (html) {
                        $('#thuePhongModalBody').html(html);
                        if ($(html).find('.alert-danger').length === 0) {
                            $('#thuePhongModalFooter').html(
                                '<button type="button" class="btn btn-secondary" id="btnStep2Back"><i class="bi bi-arrow-left"></i> Quay lai</button>' +
                                '<button type="button" class="btn btn-primary" id="btnStep2Next">Tiep tuc <i class="bi bi-arrow-right"></i></button>'
                            );
                        }
                    },
                    error: function () {
                        toastr.error('Co loi xay ra. Vui long thu lai.');
                    }
                });
            });

            $(document).on('click', '#btnStep2Back', function () {
                $.get('/ThuePhong/CreateStep1', function (html) {
                    $('#thuePhongModalBody').html(html);
                    $('#thuePhongModalFooter').html(
                        '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huy</button>' +
                        '<button type="button" class="btn btn-primary" id="btnStep1Next">Tiep tuc <i class="bi bi-arrow-right"></i></button>'
                    );
                });
            });

            $(document).on('click', '#btnStep2Next', function () {
                var form = $('#createStep2Form');
                $.ajax({
                    url: '/ThuePhong/CreateStep2',
                    type: 'POST',
                    data: form.serialize(),
                    success: function (html) {
                        $('#thuePhongModalBody').html(html);
                        if ($(html).find('.alert-danger').length === 0) {
                            $('#thuePhongModalFooter').html(
                                '<button type="button" class="btn btn-secondary" id="btnStep3Back"><i class="bi bi-arrow-left"></i> Quay lai</button>' +
                                '<button type="button" class="btn btn-success" id="btnConfirmThue"><i class="bi bi-check-circle"></i> Xac nhan thue</button>'
                            );
                        }
                    },
                    error: function () {
                        toastr.error('Co loi xay ra. Vui long thu lai.');
                    }
                });
            });

            $(document).on('click', '#btnStep3Back', function () {
                var form = $('#createConfirmForm');
                $.ajax({
                    url: '/ThuePhong/CreateStep2',
                    type: 'POST',
                    data: form.serialize(),
                    success: function (html) {
                        $('#thuePhongModalBody').html(html);
                        $('#thuePhongModalFooter').html(
                            '<button type="button" class="btn btn-secondary" id="btnStep2Back"><i class="bi bi-arrow-left"></i> Quay lai</button>' +
                            '<button type="button" class="btn btn-primary" id="btnStep2Next">Tiep tuc <i class="bi bi-arrow-right"></i></button>'
                        );
                    },
                    error: function () {
                        toastr.error('Co loi xay ra. Vui long thu lai.');
                    }
                });
            });

            $(document).on('click', '#btnConfirmThue', function () {
                var form = $('#createConfirmForm');
                $.ajax({
                    url: '/ThuePhong/CreateFinal',
                    type: 'POST',
                    data: form.serialize(),
                    success: function (response) {
                        if (response.success) {
                            thuePhongModal.hide();
                            toastr.success(response.message);
                            setTimeout(function () {
                                location.reload();
                            }, 1500);
                        } else {
                            toastr.error(response.message);
                        }
                    },
                    error: function () {
                        toastr.error('Co loi xay ra. Vui long thu lai.');
                    }
                });
            });

            $(document).on('click', '.js-tra-phong', function () {
                var id = $(this).data('id');
                $.get('/ThuePhong/TraPhong', { id: id }, function (html) {
                    $('#traPhongModalBody').html(html);
                    traPhongModal = new bootstrap.Modal($('#traPhongModal'));
                    traPhongModal.show();
                }).fail(function (xhr) {
                    var contentType = xhr.getResponseHeader('content-type') || '';
                    if (contentType.indexOf('text/html') >= 0) {
                        $('#traPhongModalBody').html(xhr.responseText);
                        traPhongModal = new bootstrap.Modal($('#traPhongModal'));
                        traPhongModal.show();
                    } else {
                        toastr.error('Khong the tai form tra phong.');
                    }
                });
            });

            $(document).on('click', '#btnConfirmTraPhong', function () {
                var form = $('#traPhongForm');
                if (!form.length) {
                    return;
                }

                $.ajax({
                    url: '/ThuePhong/TraPhong',
                    type: 'POST',
                    data: form.serialize(),
                    success: function (response) {
                        if (response.success) {
                            traPhongModal.hide();
                            toastr.success(response.message);
                            setTimeout(function () {
                                location.reload();
                            }, 1000);
                        } else {
                            $('#traPhongModalBody').html(response);
                        }
                    },
                    error: function (xhr) {
                        var contentType = xhr.getResponseHeader('content-type') || '';
                        if (contentType.indexOf('text/html') >= 0) {
                            $('#traPhongModalBody').html(xhr.responseText);
                        } else {
                            toastr.error('Co loi xay ra. Vui long thu lai.');
                        }
                    }
                });
            });
        });
    </script>
}
